<view class="tabbar-shell">
  <button
    class="tabbar-item {{active === 'cellar' ? 'is-active' : ''}}"
    data-key="cellar"
    data-url="/pages/cellar/index"
    bindtap="switchView"
  >
    <image class="tabbar-icon" src="/assets/icons/cellar-light.svg" mode="aspectFit"></image>
    <text class="tabbar-label">酒庄</text>
  </button>

  <button
    class="tabbar-item {{active === 'detail' ? 'is-active' : ''}}"
    data-key="detail"
    data-url="/pages/detail/index"
    bindtap="switchView"
  >
    <image class="tabbar-icon" src="/assets/icons/wines-light.svg" mode="aspectFit"></image>
    <text class="tabbar-label">酒款</text>
  </button>

  <button
    class="tabbar-item {{active === 'melody' ? 'is-active' : ''}}"
    data-key="melody"
    data-url="/pages/melody/index"
    bindtap="switchView"
  >
    <image class="tabbar-icon" src="/assets/icons/music-light.svg" mode="aspectFit"></image>
    <text class="tabbar-label">配乐</text>
  </button>
</view>
