.tabbar-shell {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  display: flex;
  gap: 8rpx;
  padding: 10rpx;
  border-radius: 40rpx;
  background:
    linear-gradient(180deg, rgba(20, 15, 14, 0.94), rgba(10, 7, 7, 0.96)),
    rgba(11, 8, 7, 0.9);
  border: 1rpx solid rgba(214, 177, 124, 0.12);
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(24rpx);
}

.tabbar-item {
  flex: 1;
  min-height: 76rpx;
  padding: 12rpx 8rpx 14rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: rgba(246, 239, 232, 0.52);
}

.tabbar-label {
  color: inherit;
  font-size: 18rpx;
  letter-spacing: 0.08em;
}

.tabbar-meta {
  color: inherit;
  font-size: 10rpx;
  letter-spacing: 0.3em;
  opacity: 0.84;
}

.is-active {
  background:
    linear-gradient(180deg, rgba(214, 177, 124, 0.16), rgba(214, 177, 124, 0.08)),
    rgba(214, 177, 124, 0.08);
  box-shadow: inset 0 0 0 1rpx rgba(214, 177, 124, 0.12);
  color: #f4dcc0;
}
