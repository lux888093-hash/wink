.tabbar-shell {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 20rpx;
  display: flex;
  gap: 6rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(11, 9, 8, 0.84);
  border: 1rpx solid rgba(216, 180, 128, 0.06);
  box-shadow: 0 -4rpx 14rpx rgba(0, 0, 0, 0.16);
}

.tabbar-item {
  flex: 1;
  min-height: 64rpx;
  padding: 8rpx 6rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  color: rgba(244, 235, 225, 0.52);
}

.tabbar-mark {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.22);
}

.tabbar-label,
.tabbar-meta {
  color: inherit;
}

.tabbar-label {
  font-size: 16rpx;
  letter-spacing: 0.08em;
}

.tabbar-meta {
  font-size: 11rpx;
  letter-spacing: 0.18em;
  opacity: 0.7;
}

.is-active {
  background: transparent;
  color: var(--gold);
  box-shadow: none;
}

.is-active .tabbar-mark {
  background: var(--gold);
}

.is-active .tabbar-label {
  font-weight: 600;
}
