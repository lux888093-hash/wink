<view class="dock-shell">
  <button
    class="dock-item {{active === 'home' ? 'is-active' : ''}}"
    data-key="home"
    data-url="/pages/home/index"
    bindtap="switchView"
  >
    <image class="dock-icon" src="/assets/icons/home-light.svg" mode="aspectFit"></image>
    <text class="dock-label">庄园</text>
  </button>

  <button
    class="dock-item {{active === 'store' ? 'is-active' : ''}}"
    data-key="store"
    data-url="/pages/store/index"
    bindtap="switchView"
  >
    <image class="dock-icon" src="/assets/icons/store-light.svg" mode="aspectFit"></image>
    <text class="dock-label">酒廊</text>
  </button>

  <button
    class="dock-item {{active === 'member' ? 'is-active' : ''}}"
    data-key="member"
    data-url="/pages/member/index"
    bindtap="switchView"
  >
    <image class="dock-icon" src="/assets/icons/member-light.svg" mode="aspectFit"></image>
    <text class="dock-label">会员</text>
  </button>

  <button
    class="dock-item {{active === 'cart' ? 'is-active' : ''}}"
    data-key="cart"
    data-url="/pages/cart/index"
    bindtap="switchView"
  >
    <view class="dock-badge" wx:if="{{cartCount > 0}}">{{badgeText}}</view>
    <image class="dock-icon" src="/assets/icons/bag-light.svg" mode="aspectFit"></image>
    <text class="dock-label">购物袋</text>
  </button>
</view>
