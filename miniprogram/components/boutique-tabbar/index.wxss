.dock-shell {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(26, 20, 18, 0.94), rgba(11, 8, 8, 0.96)),
    rgba(15, 11, 10, 0.92);
  border: 1rpx solid rgba(214, 177, 124, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(24rpx);
}

.dock-item {
  position: relative;
  flex: 1;
  min-height: 70rpx;
  padding: 9rpx 8rpx 10rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  color: rgba(246, 239, 232, 0.52);
}

.dock-label {
  color: inherit;
  font-size: 22rpx;
  line-height: 1;
  letter-spacing: 0;
}

.dock-meta {
  color: inherit;
  font-size: 14rpx;
  line-height: 1;
  letter-spacing: 0;
  opacity: 0.86;
}

.dock-badge {
  position: absolute;
  top: 2rpx;
  right: 10rpx;
  min-width: 30rpx;
  min-height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f1dfc0 0%, #c48a45 100%);
  color: #2a170f;
  font-size: 16rpx;
  font-weight: 700;
}

.is-active {
  background:
    linear-gradient(180deg, rgba(214, 177, 124, 0.16), rgba(214, 177, 124, 0.08)),
    rgba(214, 177, 124, 0.08);
  box-shadow: inset 0 0 0 1rpx rgba(214, 177, 124, 0.12);
  color: #f4dcc0;
}
