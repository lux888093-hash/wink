.dock-shell {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 999;
  display: flex;
  gap: 6rpx;
  padding: 8rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(28, 22, 20, 0.86), rgba(10, 8, 8, 0.9)),
    rgba(12, 9, 8, 0.78);
  border: 1rpx solid rgba(231, 200, 150, 0.14);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.26);
  backdrop-filter: saturate(180%) blur(26rpx);
  -webkit-backdrop-filter: saturate(180%) blur(26rpx);
}

.dock-item {
  position: relative;
  flex: 1;
  min-width: 0;
  min-height: 84rpx;
  padding: 10rpx 6rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  color: rgba(246, 239, 232, 0.5);
  transition: transform 0.18s ease, opacity 0.18s ease, color 0.18s ease;
}

.dock-item:active {
  transform: scale(0.97);
  opacity: 0.86;
}

.dock-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.48;
  filter: brightness(0) invert(1);
  transition: opacity 0.18s ease, filter 0.18s ease;
}

.dock-label {
  color: inherit;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
  white-space: nowrap;
}

.dock-badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  min-width: 32rpx;
  min-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5e7cd 0%, #d49b54 100%);
  color: #2a170f;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.24);
}

.is-active {
  color: #f2cf93;
  transform: translateY(-2rpx);
}

.is-active .dock-icon {
  opacity: 1;
  filter: brightness(0) saturate(100%) invert(86%) sepia(18%) saturate(1044%) hue-rotate(349deg) brightness(99%) contrast(91%);
}
