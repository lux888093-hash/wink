page {
  --bg: #0d0908;
  --bg-strong: #15100f;
  --panel: rgba(25, 19, 17, 0.8);
  --panel-strong: rgba(17, 13, 12, 0.94);
  --panel-soft: rgba(244, 235, 225, 0.05);
  --panel-line: rgba(226, 199, 159, 0.12);
  --panel-line-strong: rgba(226, 199, 159, 0.2);
  --ink: #f6efe7;
  --ink-soft: rgba(246, 239, 231, 0.72);
  --ink-faint: rgba(246, 239, 231, 0.46);
  --gold: #cfa36a;
  --gold-strong: #e7c896;
  --gold-deep: #704625;
  --wine: #5d261e;
  --paper: #efe2d1;
  --paper-deep: #e5d3bd;
  --paper-ink: #2f241d;
  --success: #8ea471;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
    radial-gradient(circle at 14% 2%, rgba(176, 118, 78, 0.2), transparent 34%),
    radial-gradient(circle at 84% 12%, rgba(231, 196, 145, 0.1), transparent 24%),
    linear-gradient(180deg, #080606 0%, #110d0c 42%, #120f0d 100%);
  color: var(--ink);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
image,
navigator,
scroll-view {
  box-sizing: border-box;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.2;
  width: auto;
}

button::after {
  border: 0;
}

.shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.page-scroll {
  position: relative;
  padding: 28rpx 22rpx 196rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(231, 200, 150, 0.84);
  font-size: 12rpx;
  letter-spacing: 0.38em;
}

.display-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 42rpx;
  line-height: 1.12;
  letter-spacing: 0.02em;
}

.section-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 30rpx;
  line-height: 1.16;
  letter-spacing: 0.01em;
}

.muted-copy {
  display: block;
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.74;
}

.micro-copy {
  display: block;
  color: var(--ink-faint);
  font-size: 17rpx;
  line-height: 1.62;
}

.line-clamp-1,
.line-clamp-2,
.line-clamp-3 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
}

.line-clamp-1 {
  -webkit-line-clamp: 1;
}

.line-clamp-2 {
  -webkit-line-clamp: 2;
}

.line-clamp-3 {
  -webkit-line-clamp: 3;
}

.section-panel {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(180deg, rgba(33, 25, 23, 0.92), rgba(18, 14, 13, 0.94)),
    rgba(18, 14, 13, 0.92);
  box-shadow: 0 22rpx 42rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(22rpx);
}

.paper-panel {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(245, 236, 223, 0.98), rgba(229, 214, 194, 0.95)),
    var(--paper);
  border: 1rpx solid rgba(99, 70, 43, 0.12);
  box-shadow: 0 18rpx 36rpx rgba(31, 20, 14, 0.08);
  color: var(--paper-ink);
}

.paper-panel .display-title,
.paper-panel .section-title {
  color: var(--paper-ink);
}

.paper-panel .muted-copy,
.paper-panel .micro-copy {
  color: rgba(47, 36, 29, 0.74);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.ghost-link {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  color: var(--gold);
  font-size: 17rpx;
  letter-spacing: 0.16em;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.16);
  background: rgba(214, 177, 124, 0.08);
  color: var(--gold);
  font-size: 15rpx;
  letter-spacing: 0.08em;
}

.paper-chip {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(63, 42, 20, 0.08);
  color: rgba(63, 42, 20, 0.82);
  font-size: 15rpx;
}

.primary-button,
.ghost-button,
.soft-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  letter-spacing: 0.06em;
}

.primary-button {
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-weight: 700;
  box-shadow: 0 18rpx 34rpx rgba(135, 91, 50, 0.22);
}

.ghost-button {
  border: 1rpx solid rgba(214, 177, 124, 0.16);
  background: rgba(255, 255, 255, 0.02);
  color: var(--ink);
}

.soft-button {
  background: rgba(244, 235, 225, 0.08);
  color: var(--ink);
}

.full-width {
  width: 100%;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price-current {
  color: var(--gold-strong);
  font-size: 32rpx;
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-variant-numeric: lining-nums;
}

.price-original {
  color: var(--ink-faint);
  font-size: 17rpx;
  text-decoration: line-through;
  font-variant-numeric: lining-nums;
}

.split-line {
  height: 1rpx;
  margin: 10rpx 0;
  background: linear-gradient(
    90deg,
    rgba(214, 177, 124, 0),
    rgba(214, 177, 124, 0.2),
    rgba(214, 177, 124, 0)
  );
}

.empty-state {
  padding-top: 170rpx;
  text-align: center;
}

.empty-title {
  display: block;
  margin-bottom: 14rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
}

.empty-subtitle {
  display: block;
  margin-bottom: 28rpx;
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.7;
}

.tabbar-gap {
  height: 152rpx;
}
