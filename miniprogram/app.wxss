page {
  --ink: #f4ebe1;
  --ink-soft: rgba(244, 235, 225, 0.76);
  --ink-faint: rgba(244, 235, 225, 0.56);
  --gold: #d8b480;
  --gold-soft: rgba(216, 180, 128, 0.2);
  --wine: #5a241d;
  --surface: #090706;
  --surface-2: #12100f;
  --surface-3: #1a1613;
  --surface-4: #241d18;
  --line: rgba(244, 235, 225, 0.1);
  --paper: #e7dbc8;
  --paper-2: #d8c6aa;
  --paper-ink: #2c2118;
  background: var(--surface);
  color: var(--ink);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
image,
navigator {
  box-sizing: border-box;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1.2;
  border: 0;
}

button::after {
  border: 0;
}

.shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top center, rgba(216, 180, 128, 0.14), transparent 30%),
    radial-gradient(circle at 82% 22%, rgba(90, 36, 29, 0.22), transparent 28%),
    linear-gradient(180deg, #050404 0%, #0d0b0a 22%, #15110f 54%, #090706 100%);
}

.page-scroll {
  padding: 20rpx 20rpx 160rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: var(--gold);
  font-size: 14rpx;
  letter-spacing: 0.28em;
  text-transform: uppercase;
}

.display-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 56rpx;
  line-height: 1.04;
}

.section-heading {
  display: block;
  margin-bottom: 14rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
  line-height: 1.16;
}

.section-card {
  position: relative;
  overflow: visible;
  border-radius: 0;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.section-card--paper {
  overflow: hidden;
  border-radius: 24rpx;
  padding: 20rpx;
  background:
    linear-gradient(180deg, rgba(241, 233, 220, 0.96), rgba(227, 214, 194, 0.94)),
    var(--paper);
  border-color: rgba(113, 81, 43, 0.18);
  border: 1rpx solid rgba(113, 81, 43, 0.12);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.1);
}

.paper-eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(113, 81, 43, 0.86);
  font-size: 14rpx;
  letter-spacing: 0.24em;
  text-transform: uppercase;
}

.paper-title {
  display: block;
  margin-bottom: 10rpx;
  color: var(--paper-ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 48rpx;
  line-height: 1.06;
}

.paper-title--small {
  font-size: 36rpx;
}

.paper-subtitle {
  display: block;
  margin-bottom: 18rpx;
  color: rgba(44, 33, 24, 0.76);
  font-size: 22rpx;
  line-height: 1.58;
}

.muted-copy {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.72;
}

.paper-copy {
  color: rgba(44, 33, 24, 0.82);
  font-size: 22rpx;
  line-height: 1.72;
}

.micro-copy {
  color: var(--ink-faint);
  font-size: 18rpx;
  line-height: 1.62;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(216, 180, 128, 0.08);
  border: 1rpx solid rgba(216, 180, 128, 0.12);
  color: var(--gold);
  font-size: 16rpx;
}

.cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f0dfc3 0%, #cf9d53 48%, #6d3f1c 100%);
  color: #20150f;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  box-shadow: 0 12rpx 30rpx rgba(133, 88, 34, 0.2);
}

.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(216, 180, 128, 0.2);
  color: var(--gold);
  font-size: 18rpx;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.empty-state {
  padding-top: 120rpx;
  text-align: center;
}

.empty-title {
  display: block;
  margin-bottom: 18rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 40rpx;
  line-height: 1.1;
}

.empty-subtitle {
  display: block;
  margin-bottom: 36rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.72;
}

.tabbar-gap {
  height: 154rpx;
}
