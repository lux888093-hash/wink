page {
  --bg: #171211;
  --bg-strong: #251515;
  --panel: rgba(43, 32, 29, 0.8);
  --panel-strong: rgba(29, 23, 21, 0.94);
  --panel-soft: rgba(247, 236, 221, 0.08);
  --panel-line: rgba(220, 185, 133, 0.16);
  --panel-line-strong: rgba(220, 185, 133, 0.28);
  --ink: #f7efe4;
  --ink-soft: rgba(255, 246, 235, 0.76);
  --ink-faint: rgba(255, 246, 235, 0.52);
  --gold: #b98c52;
  --gold-strong: #dcc08a;
  --gold-deep: #6e4c2c;
  --wine: #5d1f25;
  --wine-deep: #2a1013;
  --wine-glow: rgba(93, 31, 37, 0.26);
  --wine-line: rgba(135, 49, 54, 0.22);
  --vine: #596c52;
  --paper: #d8cebf;
  --paper-deep: #c8baa8;
  --paper-ink: #28221d;
  --success: #829873;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.16) 0%, rgba(23, 18, 17, 0) 36%),
    linear-gradient(180deg, #251515 0%, #1a1413 46%, #12100f 100%);
  color: var(--ink);
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 24rpx;
  line-height: 1.45;
}

view,
text,
button,
image,
navigator,
scroll-view {
  box-sizing: border-box;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.2;
  width: auto;
}

button::after {
  border: 0;
}

.shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.page-scroll {
  position: relative;
  padding: 30rpx 24rpx 212rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(239, 208, 155, 0.86);
  font-size: 20rpx;
  letter-spacing: 0;
}

.display-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 42rpx;
  line-height: 1.12;
  letter-spacing: 0;
}

.section-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  line-height: 1.16;
  letter-spacing: 0;
}

.muted-copy {
  display: block;
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.56;
}

.micro-copy {
  display: block;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.5;
}

.line-clamp-1,
.line-clamp-2,
.line-clamp-3 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
}

.line-clamp-1 {
  -webkit-line-clamp: 1;
}

.line-clamp-2 {
  -webkit-line-clamp: 2;
}

.line-clamp-3 {
  -webkit-line-clamp: 3;
}

.section-panel {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(135deg, rgba(93, 31, 37, 0.18) 0%, rgba(50, 43, 36, 0.06) 38%, rgba(29, 23, 21, 0) 72%),
    linear-gradient(180deg, rgba(48, 39, 33, 0.9), rgba(29, 23, 21, 0.95)),
    var(--panel-strong);
  box-shadow: 0 18rpx 34rpx rgba(18, 12, 11, 0.18);
  backdrop-filter: blur(22rpx);
}

.paper-panel {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(235, 226, 213, 0.98), rgba(209, 197, 180, 0.96)),
    var(--paper);
  border: 1rpx solid rgba(103, 76, 48, 0.12);
  box-shadow: 0 16rpx 32rpx rgba(35, 30, 24, 0.08);
  color: var(--paper-ink);
}

.paper-panel .display-title,
.paper-panel .section-title {
  color: var(--paper-ink);
}

.paper-panel .muted-copy,
.paper-panel .micro-copy {
  color: rgba(47, 36, 29, 0.74);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.ghost-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(239, 208, 155, 0.22);
  background: rgba(247, 236, 221, 0.06);
  color: var(--gold-strong);
  font-size: 22rpx;
  line-height: 1;
  letter-spacing: 0;
  transition: transform 0.18s ease, opacity 0.18s ease, background-color 0.18s ease;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(220, 185, 133, 0.2);
  background: rgba(220, 185, 133, 0.1);
  color: var(--gold);
  font-size: 20rpx;
  letter-spacing: 0;
}

.paper-chip {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(63, 42, 20, 0.08);
  color: rgba(63, 42, 20, 0.82);
  font-size: 20rpx;
}

.primary-button,
.ghost-button,
.soft-button {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
  overflow: hidden;
  transition: transform 0.18s ease, opacity 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
}

.primary-button {
  background: linear-gradient(180deg, #ead0a3 0%, #b8874c 78%, #8d5b34 100%);
  color: #241b14;
  box-shadow:
    0 10rpx 22rpx rgba(104, 76, 45, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.46);
}

.ghost-button {
  border: 1rpx solid rgba(239, 208, 155, 0.24);
  background: rgba(247, 236, 221, 0.06);
  color: var(--ink);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(18rpx);
}

.soft-button {
  background: rgba(247, 236, 221, 0.09);
  color: var(--ink);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.primary-button:active,
.ghost-button:active,
.soft-button:active,
.ghost-link:active {
  transform: scale(0.985);
  opacity: 0.88;
}

.ghost-button:active,
.soft-button:active,
.ghost-link:active {
  background: rgba(247, 236, 221, 0.12);
}

.primary-button[disabled],
.ghost-button[disabled],
.soft-button[disabled] {
  opacity: 0.42;
  box-shadow: none;
}

.full-width {
  width: 100%;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price-current {
  color: var(--gold-strong);
  font-size: 32rpx;
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-variant-numeric: lining-nums;
}

.price-original {
  color: var(--ink-faint);
  font-size: 20rpx;
  text-decoration: line-through;
  font-variant-numeric: lining-nums;
}

.split-line {
  height: 1rpx;
  margin: 10rpx 0;
  background: linear-gradient(
    90deg,
    rgba(220, 185, 133, 0),
    rgba(220, 185, 133, 0.22),
    rgba(220, 185, 133, 0)
  );
}

.empty-state {
  padding-top: 170rpx;
  text-align: center;
}

.empty-title {
  display: block;
  margin-bottom: 14rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
}

.empty-subtitle {
  display: block;
  margin-bottom: 28rpx;
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.7;
}

.tabbar-gap {
  height: 176rpx;
}
