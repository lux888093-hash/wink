.member-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.member-hero {
  position: relative;
  overflow: hidden;
  padding: 32rpx 28rpx 28rpx;
  border-radius: 36rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.1);
  background:
    radial-gradient(circle at 88% 12%, rgba(231, 200, 150, 0.13), transparent 28%),
    linear-gradient(180deg, rgba(33, 25, 23, 0.9), rgba(16, 12, 11, 0.96)),
    rgba(16, 12, 11, 0.96);
  box-shadow: 0 20rpx 38rpx rgba(0, 0, 0, 0.14);
}

.member-hero-glow {
  position: absolute;
  top: -52rpx;
  right: -36rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(231, 200, 150, 0.16), rgba(231, 200, 150, 0));
  opacity: 0.95;
  pointer-events: none;
}

.member-hero-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-kicker {
  display: block;
  color: rgba(231, 200, 150, 0.84);
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0;
}

.member-tier-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.member-tier {
  flex: 1;
  min-width: 0;
  color: var(--ink);
  font-family: "SF Pro Display", "SF Pro Text", "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: 0;
}

.member-status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0;
  border: 1rpx solid rgba(226, 199, 159, 0.12);
  background: rgba(244, 235, 225, 0.05);
}

.member-status-pill.is-active {
  color: var(--gold-strong);
  background: rgba(214, 177, 124, 0.1);
}

.member-status-pill.is-inactive {
  color: rgba(246, 239, 231, 0.76);
}

.member-summary {
  display: block;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.member-expire-row {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 38rpx;
}

.member-expire-label,
.member-expire-value {
  color: var(--ink-faint);
  font-size: 20rpx;
  line-height: 1.4;
}

.member-expire-value {
  color: var(--ink-soft);
}

.member-metrics {
  display: flex;
  gap: 12rpx;
  margin-top: 6rpx;
}

.member-metric {
  flex: 1;
  min-width: 0;
  min-height: 110rpx;
  padding: 18rpx 12rpx 16rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: rgba(244, 235, 225, 0.038);
  border: 1rpx solid rgba(214, 177, 124, 0.08);
}

.member-metric-value {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  color: var(--gold-strong);
  font-family: "SF Pro Display", "SF Pro Text", "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.06;
  text-align: center;
  font-variant-numeric: lining-nums;
}

.member-state {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 38rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: 0;
  white-space: nowrap;
}

.member-state.is-active {
  color: var(--gold-strong);
}

.member-state.is-inactive {
  color: rgba(246, 239, 231, 0.72);
}

.member-metric-label {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-faint);
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 0;
  text-align: center;
}

.member-section-head {
  display: flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 4rpx;
}

.member-section-title {
  display: block;
  color: var(--ink);
  font-family: "SF Pro Display", "SF Pro Text", "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: 0;
}

.track-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.track-card {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  min-width: 0;
  padding: 22rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    linear-gradient(180deg, rgba(24, 19, 17, 0.76), rgba(15, 11, 10, 0.9)),
    rgba(15, 11, 10, 0.88);
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.1);
}

.track-cover {
  width: 148rpx;
  height: 168rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.04);
}

.track-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
}

.track-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.track-title {
  color: var(--ink);
  font-family: "SF Pro Display", "SF Pro Text", "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.28;
  letter-spacing: 0;
}

.track-description {
  display: block;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.48;
}

.track-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.track-icon-button,
.track-unlock-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 999rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.12);
  background: rgba(244, 235, 225, 0.05);
}

.track-icon-button {
  width: 68rpx;
  height: 68rpx;
}

.track-unlock-button {
  min-width: 106rpx;
  height: 68rpx;
  padding: 0 22rpx;
  color: var(--gold);
  font-size: 22rpx;
  font-weight: 600;
}

.track-icon-active {
  opacity: 0.84;
  transform: scale(0.96);
}

.track-play-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 20rpx solid rgba(246, 239, 231, 0.82);
}

.track-download-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.track-download-stem {
  position: absolute;
  z-index: 2;
  left: 14rpx;
  top: 3rpx;
  width: 3rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 239, 231, 0.78);
}

.track-download-arrow {
  position: absolute;
  z-index: 2;
  left: 9rpx;
  top: 12rpx;
  width: 11rpx;
  height: 11rpx;
  border-right: 3rpx solid rgba(246, 239, 231, 0.78);
  border-bottom: 3rpx solid rgba(246, 239, 231, 0.78);
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.track-download-tray {
  position: absolute;
  left: 4rpx;
  top: 15rpx;
  width: 24rpx;
  height: 13rpx;
  border-right: 3rpx solid rgba(246, 239, 231, 0.78);
  border-bottom: 3rpx solid rgba(246, 239, 231, 0.78);
  border-left: 3rpx solid rgba(246, 239, 231, 0.78);
  border-radius: 0 0 15rpx 15rpx;
}

.download-panel {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    linear-gradient(180deg, rgba(24, 19, 17, 0.72), rgba(15, 11, 10, 0.88)),
    rgba(15, 11, 10, 0.86);
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.08);
}

.download-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(214, 177, 124, 0.08);
}

.download-item:last-child {
  border-bottom: 0;
}

.download-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.download-name {
  color: var(--ink);
  font-size: 22rpx;
  line-height: 1.45;
}

.download-time {
  color: var(--ink-faint);
  font-size: 20rpx;
  line-height: 1.4;
}

.download-mark {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(231, 200, 150, 0.74);
  box-shadow: 0 0 16rpx rgba(231, 200, 150, 0.28);
}

.empty-inline {
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background: rgba(244, 235, 225, 0.03);
}

.empty-inline .muted-copy {
  font-size: 22rpx;
  line-height: 1.5;
}
