.member-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.member-hero {
  padding: 28rpx 24rpx 26rpx;
}

.member-metrics {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.member-metric {
  flex: 1;
  min-height: 94rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(244, 235, 225, 0.04);
  border: 1rpx solid rgba(214, 177, 124, 0.08);
}

.member-metric-value {
  display: block;
  margin-bottom: 8rpx;
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 28rpx;
}

.member-metric-label {
  display: block;
  color: var(--ink-faint);
  font-size: 15rpx;
  letter-spacing: 0.16em;
}

.plan-list,
.track-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.plan-card {
  padding: 24rpx;
}

.plan-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.plan-name {
  display: block;
  color: var(--paper-ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 28rpx;
}

.plan-badge {
  display: block;
  margin-top: 8rpx;
  color: rgba(43, 33, 27, 0.54);
  font-size: 16rpx;
}

.plan-price {
  color: rgba(82, 51, 19, 0.9);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
}

.plan-button {
  margin-top: 18rpx;
}

.track-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  gap: 14rpx;
  padding: 16rpx;
}

.track-cover {
  width: 148rpx;
  height: 168rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.track-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.track-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 27rpx;
}

.track-actions {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  overflow: hidden;
}

.track-icon-button,
.track-unlock-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 52rpx;
  height: 52rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.18);
  background: rgba(244, 235, 225, 0.07);
}

.track-unlock-button {
  color: var(--gold);
  font-size: 18rpx;
}

.track-icon-active {
  opacity: 0.84;
  transform: scale(0.96);
}

.track-play-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid var(--ink);
}

.track-download-icon {
  position: relative;
  width: 28rpx;
  height: 30rpx;
}

.track-download-stem {
  position: absolute;
  left: 12rpx;
  top: 2rpx;
  width: 4rpx;
  height: 18rpx;
  border-radius: 999rpx;
  color: var(--gold);
  background: currentColor;
}

.track-download-arrow {
  position: absolute;
  left: 6rpx;
  top: 13rpx;
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid var(--gold);
  border-bottom: 4rpx solid var(--gold);
  transform: rotate(45deg);
}

.track-download-tray {
  position: absolute;
  left: 4rpx;
  bottom: 0;
  width: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: var(--gold);
}

.download-panel {
  padding: 20rpx 22rpx;
}

.download-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 0 14rpx;
  border-bottom: 1rpx solid rgba(214, 177, 124, 0.08);
}

.download-item:first-child {
  padding-top: 0;
}

.download-name {
  color: var(--ink);
  font-size: 20rpx;
}

.download-time {
  color: var(--ink-faint);
  font-size: 16rpx;
}

.empty-inline {
  padding: 22rpx;
}
