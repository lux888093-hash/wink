.member-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.member-hero {
  padding: 28rpx 24rpx 22rpx;
}

.member-metrics {
  display: flex;
  gap: 8rpx;
  margin-top: 14rpx;
}

.member-metric {
  flex: 1;
  min-width: 0;
  min-height: 76rpx;
  padding: 10rpx 8rpx;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: rgba(244, 235, 225, 0.035);
  border: 1rpx solid rgba(214, 177, 124, 0.1);
}

.member-metric-value {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 28rpx;
  line-height: 1;
  text-align: center;
}

.member-state {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 30rpx;
  margin-bottom: 6rpx;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
  white-space: nowrap;
}

.member-state.is-active {
  color: var(--gold-strong);
}

.member-state.is-inactive {
  color: rgba(246, 239, 231, 0.72);
}

.member-metric-label {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-faint);
  font-size: 14rpx;
  line-height: 1;
  letter-spacing: 0;
  text-align: center;
}

.track-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.track-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  gap: 14rpx;
  padding: 16rpx;
}

.track-cover {
  width: 148rpx;
  height: 168rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.track-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.track-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 27rpx;
}

.track-actions {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  overflow: hidden;
}

.track-icon-button,
.track-unlock-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 8rpx;
}

.track-icon-button {
  width: 48rpx;
  height: 48rpx;
}

.track-unlock-button {
  width: 52rpx;
  height: 48rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.18);
  background: rgba(244, 235, 225, 0.07);
  color: var(--gold);
  font-size: 18rpx;
}

.track-icon-active {
  opacity: 0.84;
  transform: scale(0.96);
}

.track-play-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid rgba(246, 239, 231, 0.78);
}

.track-download-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.track-download-stem {
  position: absolute;
  z-index: 2;
  left: 14rpx;
  top: 3rpx;
  width: 3rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 239, 231, 0.78);
}

.track-download-arrow {
  position: absolute;
  z-index: 2;
  left: 9rpx;
  top: 12rpx;
  width: 11rpx;
  height: 11rpx;
  border-right: 3rpx solid rgba(246, 239, 231, 0.78);
  border-bottom: 3rpx solid rgba(246, 239, 231, 0.78);
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.track-download-tray {
  position: absolute;
  left: 4rpx;
  top: 15rpx;
  width: 24rpx;
  height: 13rpx;
  border-right: 3rpx solid rgba(246, 239, 231, 0.78);
  border-bottom: 3rpx solid rgba(246, 239, 231, 0.78);
  border-left: 3rpx solid rgba(246, 239, 231, 0.78);
  border-radius: 0 0 15rpx 15rpx;
}

.download-panel {
  padding: 20rpx 22rpx;
}

.download-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 0 14rpx;
  border-bottom: 1rpx solid rgba(214, 177, 124, 0.08);
}

.download-item:first-child {
  padding-top: 0;
}

.download-name {
  color: var(--ink);
  font-size: 20rpx;
}

.download-time {
  color: var(--ink-faint);
  font-size: 16rpx;
}

.empty-inline {
  padding: 22rpx;
}
