.estate-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 24rpx 212rpx;
  background: var(--bg);
}

.estate-hero {
  position: relative;
  min-height: 840rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  background: var(--bg);
}

.estate-hero-image,
.estate-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.estate-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.18) 0%, rgba(24, 21, 18, 0) 46%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.08) 0%, rgba(42, 16, 19, 0.22) 34%, rgba(18, 14, 13, 0.8) 100%),
    linear-gradient(90deg, rgba(24, 18, 17, 0.66) 0%, rgba(24, 21, 18, 0.16) 52%, rgba(24, 18, 17, 0.54) 100%);
}

.estate-hero-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 70rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.estate-kicker,
.estate-chapter-eyebrow,
.estate-fact-label {
  display: block;
  color: rgba(231, 200, 150, 0.78);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.estate-title {
  display: block;
  max-width: 600rpx;
  margin: 18rpx 0 14rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 64rpx;
  font-weight: 600;
  line-height: 1.04;
  letter-spacing: 0;
}

.estate-tagline {
  display: block;
  max-width: 580rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.34;
  letter-spacing: 0;
}

.estate-intro {
  display: block;
  max-width: 620rpx;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.58;
  letter-spacing: 0;
}

.estate-facts {
  display: flex;
  gap: 0;
  margin: 0 -24rpx;
  padding: 30rpx 24rpx 42rpx;
  background: var(--bg);
}

.estate-fact {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  border-left: 1rpx solid rgba(231, 200, 150, 0.14);
}

.estate-fact:first-child {
  border-left: 0;
  padding-left: 0;
}

.estate-fact:last-child {
  padding-right: 0;
}

.estate-fact-value {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.36;
  letter-spacing: 0;
}

.estate-statement {
  margin: 0 -24rpx;
  padding: 72rpx 30rpx 76rpx;
  background: var(--paper);
  color: var(--paper-ink);
}

.estate-statement-kicker {
  display: block;
  color: rgba(49, 37, 31, 0.58);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.estate-statement-title {
  display: block;
  max-width: 640rpx;
  margin-top: 18rpx;
  color: var(--paper-ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: 0;
}

.estate-statement-body {
  display: block;
  max-width: 640rpx;
  margin-top: 22rpx;
  color: rgba(49, 37, 31, 0.74);
  font-size: 25rpx;
  line-height: 1.62;
  letter-spacing: 0;
}

.estate-chapters {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0 -24rpx;
}

.estate-chapter {
  position: relative;
  min-height: 700rpx;
  overflow: hidden;
  background: var(--bg-strong);
}

.estate-chapter-image,
.estate-chapter-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.estate-chapter-mask {
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.14) 0%, rgba(24, 21, 18, 0) 50%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.06) 0%, rgba(42, 16, 19, 0.18) 44%, rgba(18, 14, 13, 0.8) 100%),
    linear-gradient(90deg, rgba(24, 18, 17, 0.5), rgba(24, 21, 18, 0.06) 58%, rgba(24, 18, 17, 0.5));
}

.estate-chapter-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 52rpx;
  z-index: 2;
}

.estate-chapter-title {
  display: block;
  max-width: 610rpx;
  margin-top: 14rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: 0;
}

.estate-chapter-body {
  display: block;
  max-width: 620rpx;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.62;
  letter-spacing: 0;
}

.estate-age-note {
  display: block;
  margin: 0 -24rpx;
  padding: 34rpx 30rpx 0;
  background: var(--bg);
  color: rgba(246, 239, 231, 0.46);
  font-size: 20rpx;
  line-height: 1.5;
  text-align: center;
  letter-spacing: 0;
}
