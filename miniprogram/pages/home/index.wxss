.estate-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 24rpx 212rpx;
}

.estate-hero {
  position: relative;
  min-height: 780rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  border-radius: 0 0 38rpx 38rpx;
  background: #050404;
}

.estate-hero-image,
.estate-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.estate-hero-mask {
  background:
    linear-gradient(180deg, rgba(5, 4, 4, 0.04) 0%, rgba(5, 4, 4, 0.3) 42%, rgba(5, 4, 4, 0.92) 100%),
    linear-gradient(90deg, rgba(5, 4, 4, 0.76) 0%, rgba(5, 4, 4, 0.14) 56%, rgba(5, 4, 4, 0.72) 100%);
}

.estate-hero-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 56rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.estate-kicker,
.estate-statement-kicker,
.estate-chapter-eyebrow,
.estate-fact-label {
  display: block;
  color: rgba(231, 200, 150, 0.8);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.estate-title {
  display: block;
  max-width: 560rpx;
  margin: 18rpx 0 14rpx;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: 0;
}

.estate-tagline {
  display: block;
  max-width: 560rpx;
  color: rgba(246, 239, 231, 0.82);
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.35;
  letter-spacing: 0;
}

.estate-intro {
  display: block;
  max-width: 610rpx;
  margin-top: 18rpx;
  color: rgba(246, 239, 231, 0.72);
  font-size: 23rpx;
  line-height: 1.58;
  letter-spacing: 0;
}

.estate-facts {
  display: flex;
  gap: 12rpx;
  padding: 22rpx 0 42rpx;
}

.estate-fact {
  flex: 1;
  min-width: 0;
  padding: 20rpx 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(231, 200, 150, 0.18);
}

.estate-fact-value {
  display: block;
  margin-top: 10rpx;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
  letter-spacing: 0;
}

.estate-statement {
  padding: 14rpx 2rpx 44rpx;
}

.estate-statement-title {
  display: block;
  max-width: 620rpx;
  margin-top: 16rpx;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.12;
  letter-spacing: 0;
}

.estate-statement-body {
  display: block;
  max-width: 620rpx;
  margin-top: 18rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.62;
  letter-spacing: 0;
}

.estate-chapters {
  display: flex;
  flex-direction: column;
  gap: 54rpx;
}

.estate-chapter {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.estate-chapter-image {
  width: 100%;
  height: 370rpx;
  border-radius: 28rpx;
  background: rgba(244, 235, 225, 0.04);
}

.estate-chapter-copy {
  padding: 0 2rpx 0;
}

.estate-chapter-title {
  display: block;
  margin-top: 12rpx;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.16;
  letter-spacing: 0;
}

.estate-chapter-body {
  display: block;
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.62;
  letter-spacing: 0;
}

.estate-age-note {
  display: block;
  margin-top: 48rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(231, 200, 150, 0.14);
  color: var(--ink-faint);
  font-size: 20rpx;
  line-height: 1.5;
  text-align: center;
  letter-spacing: 0;
}
