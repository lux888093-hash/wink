.estate-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 24rpx 212rpx;
  background:
    linear-gradient(180deg, rgba(37, 21, 21, 0.92) 0%, rgba(23, 18, 17, 1) 32%, rgba(18, 16, 15, 1) 100%),
    var(--bg);
}

.estate-hero {
  position: relative;
  min-height: 920rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  background: var(--bg);
}

.estate-hero-image,
.estate-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.estate-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.16) 0%, rgba(24, 21, 18, 0) 48%),
    linear-gradient(180deg, rgba(16, 13, 12, 0.04) 0%, rgba(42, 16, 19, 0.18) 46%, rgba(18, 14, 13, 0.94) 100%),
    linear-gradient(90deg, rgba(18, 14, 13, 0.62) 0%, rgba(24, 21, 18, 0.08) 52%, rgba(18, 14, 13, 0.24) 100%);
}

.estate-hero-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 146rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 520rpx;
}

.estate-kicker,
.estate-chapter-eyebrow,
.estate-fact-label {
  display: block;
  color: rgba(231, 200, 150, 0.78);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.estate-title {
  display: block;
  max-width: 520rpx;
  margin: 16rpx 0 12rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 62rpx;
  font-weight: 600;
  line-height: 1.04;
  letter-spacing: 0;
}

.estate-tagline {
  display: block;
  max-width: 420rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.34;
  letter-spacing: 0;
}

.estate-facts {
  display: flex;
  gap: 0;
  position: relative;
  z-index: 3;
  margin: -112rpx -24rpx 0;
  padding: 26rpx 24rpx 50rpx;
  border-top: 1rpx solid rgba(220, 185, 133, 0.18);
  background:
    linear-gradient(180deg, rgba(23, 18, 17, 0.14), rgba(23, 18, 17, 0.96) 46%, rgba(23, 18, 17, 1) 100%);
  backdrop-filter: blur(18rpx);
}

.estate-fact {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  border-left: 1rpx solid rgba(231, 200, 150, 0.14);
}

.estate-fact:first-child {
  border-left: 0;
  padding-left: 0;
}

.estate-fact:last-child {
  padding-right: 0;
}

.estate-fact-value {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.36;
  letter-spacing: 0;
}

.estate-statement {
  margin: 0 -24rpx;
  min-height: 184rpx;
  padding: 42rpx 30rpx 44rpx;
  display: flex;
  align-items: center;
  background:
    linear-gradient(90deg, rgba(220, 185, 133, 0.14), rgba(220, 185, 133, 0) 36%),
    linear-gradient(180deg, rgba(31, 24, 21, 0.98), rgba(18, 14, 13, 1));
  color: var(--paper-ink);
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
}

.estate-statement-copy {
  flex: 1;
  min-width: 0;
}

.estate-statement-kicker {
  display: block;
  color: rgba(231, 200, 150, 0.72);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.estate-statement-title {
  display: block;
  max-width: 560rpx;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.94);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: 0;
}

.estate-chapters {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0 -24rpx;
  padding: 0;
  background: var(--bg);
}

.estate-chapter {
  position: relative;
  min-height: 560rpx;
  overflow: hidden;
  background: var(--bg-strong);
}

.estate-chapter:first-child {
  min-height: 680rpx;
}

.estate-chapter-image,
.estate-chapter-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.estate-chapter-mask {
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.12) 0%, rgba(24, 21, 18, 0) 52%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.02) 0%, rgba(42, 16, 19, 0.1) 42%, rgba(18, 14, 13, 0.86) 100%),
    linear-gradient(90deg, rgba(24, 18, 17, 0.52), rgba(24, 21, 18, 0.02) 62%, rgba(24, 18, 17, 0.22));
}

.estate-chapter-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 34rpx;
  z-index: 2;
}

.estate-chapter-title {
  display: block;
  max-width: 560rpx;
  margin-top: 12rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: 0;
}

.estate-age-note {
  display: block;
  margin: 0 -24rpx;
  padding: 34rpx 30rpx 0;
  background: var(--bg);
  color: rgba(246, 239, 231, 0.46);
  font-size: 20rpx;
  line-height: 1.5;
  text-align: center;
  letter-spacing: 0;
}
