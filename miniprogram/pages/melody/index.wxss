.melody-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.melody-stage {
  position: relative;
  min-height: 344rpx;
  border-radius: 36rpx;
  overflow: hidden;
}

.melody-stage-bg,
.melody-stage-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.melody-stage-mask {
  background:
    linear-gradient(180deg, rgba(7, 6, 6, 0.08) 0%, rgba(7, 6, 6, 0.84) 100%),
    radial-gradient(circle at 78% 14%, rgba(255, 239, 198, 0.18), rgba(255, 239, 198, 0));
}

.melody-stage-copy {
  position: relative;
  z-index: 2;
  padding: 32rpx 28rpx 28rpx;
}

.player-card {
  padding: 24rpx;
}

.player-head {
  display: flex;
  gap: 14rpx;
}

.player-cover {
  width: 170rpx;
  height: 194rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.player-copy {
  flex: 1;
}

.player-kicker {
  color: rgba(63, 42, 20, 0.62);
}

.progress-wrap {
  margin-top: 20rpx;
}

.progress-rail {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(43, 33, 27, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c48a45 0%, #f0dfc3 100%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  color: rgba(43, 33, 27, 0.56);
  font-size: 14rpx;
}

.control-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
}

.player-mini {
  flex: 1;
}

.player-main {
  flex: 1.2;
}

.gate-panel {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(63, 42, 20, 0.08);
}

.gate-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.gate-button {
  flex: 1;
}

.track-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.track-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(214, 177, 124, 0.08);
}

.track-item.is-active {
  color: var(--gold-strong);
}

.track-no {
  width: 48rpx;
  color: rgba(214, 177, 124, 0.72);
  text-align: center;
}

.track-main {
  flex: 1;
}

.track-name {
  display: block;
  margin-bottom: 6rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 26rpx;
}

.track-time {
  color: var(--ink-faint);
  font-size: 16rpx;
}
