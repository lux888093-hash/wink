.melody-page {
  position: relative;
  min-height: 100vh;
  padding: 0 0 230rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.melody-bg,
.melody-bg-shadow,
.melody-bg-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.melody-bg {
  transform: scale(1.1);
  filter: blur(8rpx);
}

.melody-bg-shadow {
  background:
    linear-gradient(180deg, rgba(239, 208, 155, 0.08), rgba(24, 21, 18, 0.2));
}

.melody-bg-overlay {
  background:
    linear-gradient(180deg, rgba(31, 27, 23, 0.12) 0%, rgba(31, 27, 23, 0.26) 28%, rgba(24, 21, 18, 0.8) 100%),
    linear-gradient(90deg, rgba(24, 21, 18, 0.14) 0%, rgba(24, 21, 18, 0) 42%, rgba(24, 21, 18, 0.14) 100%);
}

.melody-topbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 34rpx 0;
  min-height: 94rpx;
}

.topbar-button {
  width: 48rpx;
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.topbar-icon {
  width: 32rpx;
  height: 32rpx;
}

.topbar-title {
  color: #efe9e4;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
}

.melody-stage {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  text-align: center;
  padding: 34rpx 34rpx 0;
}

.cover-shell {
  position: relative;
  width: 404rpx;
  height: 404rpx;
  margin: 0 auto 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 30rpx 86rpx rgba(18, 15, 12, 0.38);
  background: rgba(50, 43, 36, 0.86);
}

.cover-image {
  width: 100%;
  height: 100%;
  transition: transform 1s ease;
}

.cover-shell:active .cover-image {
  transform: scale(1.04);
}

.melody-kicker {
  margin-top: 98rpx;
  margin-bottom: 14rpx;
  color: rgba(239, 208, 155, 0.86);
  font-size: 20rpx;
  letter-spacing: 0;
}

.progress-wrap {
  width: 100%;
  margin-top: 48rpx;
}

.progress-rail {
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.14);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #dcc08a 0%, #8f6a46 100%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  color: rgba(255, 246, 235, 0.58);
  font-size: 20rpx;
  letter-spacing: 0;
}

.melody-title {
  margin-top: 0;
  color: #f7efe4;
  font-size: 76rpx;
  line-height: 0.98;
  font-style: italic;
  text-shadow: 0 8rpx 24rpx rgba(18, 15, 12, 0.24);
}

.melody-description {
  max-width: 590rpx;
  margin-top: 28rpx;
  color: rgba(255, 246, 235, 0.72);
  font-size: 22rpx;
  line-height: 1.72;
  font-style: italic;
}

.gate-message {
  display: block;
  max-width: 590rpx;
  margin-top: 22rpx;
  color: rgba(239, 208, 155, 0.92);
  font-size: 20rpx;
  line-height: 1.6;
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 78rpx;
  margin-top: 62rpx;
}

.melody-actions {
  display: flex;
  width: 100%;
  gap: 18rpx;
  margin-top: 42rpx;
}

.melody-action {
  flex: 1;
}

.control-side,
.control-main {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  flex: none;
  box-sizing: border-box;
}

.control-side {
  width: 58rpx;
  height: 58rpx;
}

.control-main {
  width: 86rpx;
  height: 86rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #ead0a3 0%, #6d5140 100%);
  box-shadow: 0 16rpx 30rpx rgba(70, 45, 35, 0.22);
}

.control-touch-active {
  opacity: 0.88;
  transform: scale(0.98);
}

.skip-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
}

.skip-prev {
  flex-direction: row;
}

.skip-next {
  flex-direction: row-reverse;
}

.skip-bar {
  width: 4rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: rgba(231, 226, 225, 0.82);
}

.skip-triangle {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

.skip-triangle-prev {
  border-right: 12rpx solid rgba(231, 226, 225, 0.82);
}

.skip-triangle-next {
  border-left: 12rpx solid rgba(231, 226, 225, 0.82);
}

.skip-triangle.overlap {
  margin-left: -3rpx;
  margin-right: -3rpx;
}

.pause-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.pause-bar {
  width: 7rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #241b14;
}

.play-icon-shape {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #241b14;
}
