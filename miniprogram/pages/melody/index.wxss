.melody-page {
  position: relative;
  min-height: 100vh;
  padding: 26rpx 34rpx 230rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.melody-bg,
.melody-bg-shadow,
.melody-bg-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.melody-bg {
  transform: scale(1.1);
  filter: blur(10rpx);
}

.melody-bg-shadow {
  background:
    radial-gradient(circle at 86% 18%, rgba(242, 216, 168, 0.12), rgba(242, 216, 168, 0)),
    radial-gradient(circle at 12% 12%, rgba(104, 28, 18, 0.22), rgba(104, 28, 18, 0)),
    radial-gradient(circle at 50% 100%, rgba(0, 0, 0, 0.36), rgba(0, 0, 0, 0));
}

.melody-bg-overlay {
  background:
    linear-gradient(180deg, rgba(8, 7, 7, 0.28) 0%, rgba(8, 7, 7, 0.42) 42%, rgba(8, 7, 7, 0.9) 100%),
    linear-gradient(90deg, rgba(8, 7, 7, 0.26) 0%, rgba(8, 7, 7, 0) 42%, rgba(8, 7, 7, 0.2) 100%);
}

.melody-topbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
}

.topbar-button {
  width: 52rpx;
  height: 52rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.topbar-icon {
  width: 34rpx;
  height: 34rpx;
}

.topbar-title {
  color: #ece6e1;
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 0.12em;
}

.melody-stage {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.cover-shell {
  position: relative;
  width: 406rpx;
  height: 406rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 34rpx 100rpx rgba(0, 0, 0, 0.52);
  background: rgba(53, 53, 52, 0.85);
}

.cover-image {
  width: 100%;
  height: 100%;
  transition: transform 1s ease;
}

.cover-shell:active .cover-image {
  transform: scale(1.04);
}

.cover-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  margin-left: -32rpx;
  margin-top: -32rpx;
  border-radius: 18rpx;
  background: rgba(12, 8, 8, 0.84);
  border: 1rpx solid rgba(59, 47, 44, 0.5);
  backdrop-filter: blur(10rpx);
}

.melody-kicker {
  margin-top: 94rpx;
  margin-bottom: 14rpx;
  color: rgba(231, 200, 150, 0.84);
  font-size: 13rpx;
  letter-spacing: 0.36em;
}

.progress-wrap {
  width: 100%;
  margin-top: 52rpx;
}

.progress-rail {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(53, 53, 52, 0.88);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffb4a8 0%, #e9c176 100%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  color: rgba(163, 139, 136, 0.88);
  font-size: 14rpx;
  letter-spacing: 0.24em;
}

.melody-title {
  margin-top: 12rpx;
  color: #e5e2e1;
  font-size: 82rpx;
  line-height: 0.98;
  font-style: italic;
  text-shadow: 0 0 20rpx rgba(233, 193, 118, 0.3);
}

.melody-description {
  max-width: 580rpx;
  margin-top: 28rpx;
  color: rgba(168, 161, 159, 0.88);
  font-size: 30rpx;
  line-height: 1.58;
  font-style: italic;
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 74rpx;
  margin-top: 58rpx;
}

.control-side,
.control-main {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.control-side {
  width: 60rpx;
  height: 60rpx;
}

.control-main {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb4a8 0%, #520000 100%);
  box-shadow: 0 18rpx 34rpx rgba(82, 0, 0, 0.22);
}

.control-side-icon {
  width: 44rpx;
  height: 44rpx;
}

.control-main-icon {
  width: 54rpx;
  height: 54rpx;
}

.play-icon {
  margin-left: 6rpx;
}

.gate-inline {
  margin-top: 42rpx;
}

.gate-copy {
  color: rgba(246, 239, 231, 0.66);
}

.gate-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.gate-link,
.gate-sep {
  color: rgba(231, 200, 150, 0.92);
  font-size: 18rpx;
  letter-spacing: 0.12em;
}

.selector-wrap {
  width: 100%;
  margin-top: 90rpx;
}

.selector-label {
  display: block;
  margin-bottom: 24rpx;
  color: rgba(231, 193, 118, 0.56);
  font-size: 14rpx;
  letter-spacing: 0.4em;
}

.selector-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.track-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 314rpx;
  min-height: 58rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(28, 27, 27, 0.34);
  color: rgba(168, 161, 159, 0.84);
  font-size: 18rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  backdrop-filter: blur(14rpx);
}

.track-chip.is-active {
  background: rgba(96, 68, 3, 0.3);
  border: 1rpx solid rgba(233, 193, 118, 0.2);
  color: #e9c176;
  box-shadow: 0 18rpx 32rpx rgba(233, 193, 118, 0.06);
}
