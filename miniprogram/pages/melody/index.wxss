.melody-page {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.melody-stage {
  position: relative;
  min-height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #0e0c0b;
}

.melody-stage-bg,
.melody-stage-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.melody-stage-mask {
  background:
    linear-gradient(180deg, rgba(7, 6, 6, 0.08) 0%, rgba(7, 6, 6, 0.78) 100%),
    radial-gradient(circle at 78% 14%, rgba(255, 239, 198, 0.18), rgba(255, 239, 198, 0));
}

.melody-stage-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 320rpx;
  padding: 22rpx 22rpx;
}

.melody-stage-subtitle {
  display: block;
  max-width: 420rpx;
  margin-top: 10rpx;
  color: rgba(244, 235, 225, 0.8);
  font-size: 22rpx;
  line-height: 1.64;
}

.melody-player-card {
  padding-top: 24rpx;
}

.player-top {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.player-cover {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.14);
}

.player-cover--playing {
  box-shadow: 0 12rpx 28rpx rgba(133, 88, 34, 0.16);
}

.progress-wrap {
  margin-top: 20rpx;
}

.progress-rail {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(44, 33, 24, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c48a45 0%, #f0dfc3 100%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  color: rgba(44, 33, 24, 0.62);
  font-size: 14rpx;
  letter-spacing: 0.08em;
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.control-key {
  min-width: 86rpx;
  min-height: 58rpx;
  border-radius: 999rpx;
  background: rgba(44, 33, 24, 0.04);
  color: rgba(44, 33, 24, 0.72);
  font-size: 16rpx;
  letter-spacing: 0.04em;
}

.control-play {
  min-width: 122rpx;
  min-height: 122rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f0dfc3 0%, #cf9d53 48%, #6d3f1c 100%);
  color: #20150f;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  box-shadow: 0 10rpx 22rpx rgba(133, 88, 34, 0.18);
}

.melody-note {
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(216, 180, 128, 0.12);
}

.melody-note-title {
  margin-bottom: 8rpx;
}

.track-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.track-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(216, 180, 128, 0.1);
}

.track-no {
  width: 48rpx;
  color: rgba(216, 180, 128, 0.7);
  font-size: 16rpx;
  letter-spacing: 0.08em;
  text-align: center;
  flex-shrink: 0;
}

.track-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.track-copy {
  flex: 1;
}

.track-mood {
  display: block;
  margin-bottom: 4rpx;
  color: var(--gold);
  font-size: 12rpx;
  letter-spacing: 0.16em;
}

.track-title {
  display: block;
  margin-bottom: 6rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 26rpx;
  line-height: 1.1;
}

.track-description {
  display: block;
  color: var(--ink-soft);
  font-size: 18rpx;
  line-height: 1.5;
}

.track-time {
  color: var(--ink-faint);
  font-size: 14rpx;
  letter-spacing: 0.08em;
}

.track-card--active {
  background: linear-gradient(90deg, rgba(216, 180, 128, 0.06), rgba(216, 180, 128, 0));
}
