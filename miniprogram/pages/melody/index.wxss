.melody-page {
  position: relative;
  min-height: 100vh;
  padding: 0 0 230rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.melody-bg,
.melody-bg-shadow,
.melody-bg-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.melody-bg {
  transform: scale(1.1);
  filter: blur(8rpx);
}

.melody-bg-shadow {
  background:
    radial-gradient(circle at 86% 18%, rgba(242, 216, 168, 0.08), rgba(242, 216, 168, 0)),
    radial-gradient(circle at 50% 100%, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0));
}

.melody-bg-overlay {
  background:
    linear-gradient(180deg, rgba(8, 7, 7, 0.1) 0%, rgba(8, 7, 7, 0.28) 28%, rgba(8, 7, 7, 0.86) 100%),
    linear-gradient(90deg, rgba(8, 7, 7, 0.12) 0%, rgba(8, 7, 7, 0) 42%, rgba(8, 7, 7, 0.12) 100%);
}

.melody-topbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 34rpx 0;
  min-height: 94rpx;
}

.topbar-button {
  width: 48rpx;
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.topbar-icon {
  width: 32rpx;
  height: 32rpx;
}

.topbar-title {
  color: #efe9e4;
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0.1em;
}

.melody-stage {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  text-align: center;
  padding: 34rpx 34rpx 0;
}

.cover-shell {
  position: relative;
  width: 404rpx;
  height: 404rpx;
  margin: 0 auto 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 34rpx 100rpx rgba(0, 0, 0, 0.52);
  background: rgba(53, 53, 52, 0.85);
}

.cover-image {
  width: 100%;
  height: 100%;
  transition: transform 1s ease;
}

.cover-shell:active .cover-image {
  transform: scale(1.04);
}

.cover-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 66rpx;
  height: 66rpx;
  margin-left: -33rpx;
  margin-top: -33rpx;
  border-radius: 16rpx;
  background: rgba(12, 8, 8, 0.84);
  border: 1rpx solid rgba(59, 47, 44, 0.5);
  backdrop-filter: blur(10rpx);
}

.melody-kicker {
  margin-top: 98rpx;
  margin-bottom: 14rpx;
  color: rgba(231, 200, 150, 0.84);
  font-size: 13rpx;
  letter-spacing: 0.36em;
}

.progress-wrap {
  width: 100%;
  margin-top: 48rpx;
}

.progress-rail {
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(53, 53, 52, 0.9);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f2a899 0%, #d9b96d 100%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  color: rgba(163, 139, 136, 0.88);
  font-size: 14rpx;
  letter-spacing: 0.24em;
}

.melody-title {
  margin-top: 0;
  color: #e5e2e1;
  font-size: 82rpx;
  line-height: 0.98;
  font-style: italic;
  text-shadow: 0 0 20rpx rgba(233, 193, 118, 0.3);
}

.melody-description {
  max-width: 590rpx;
  margin-top: 28rpx;
  color: rgba(168, 161, 159, 0.9);
  font-size: 22rpx;
  line-height: 1.72;
  font-style: italic;
}

.gate-message {
  display: block;
  max-width: 590rpx;
  margin-top: 22rpx;
  color: rgba(231, 200, 150, 0.92);
  font-size: 20rpx;
  line-height: 1.6;
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 78rpx;
  margin-top: 62rpx;
}

.melody-actions {
  display: flex;
  width: 100%;
  gap: 18rpx;
  margin-top: 42rpx;
}

.melody-action {
  flex: 1;
}

.control-side,
.control-main {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  flex: none;
  box-sizing: border-box;
}

.control-side {
  width: 58rpx;
  height: 58rpx;
}

.control-main {
  width: 86rpx;
  height: 86rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f2b0a4 0%, #5e1810 100%);
  box-shadow: 0 18rpx 34rpx rgba(82, 0, 0, 0.22);
}

.control-touch-active {
  opacity: 0.88;
  transform: scale(0.98);
}

.skip-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
}

.skip-prev {
  flex-direction: row;
}

.skip-next {
  flex-direction: row-reverse;
}

.skip-bar {
  width: 4rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: rgba(231, 226, 225, 0.82);
}

.skip-triangle {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

.skip-triangle-prev {
  border-right: 12rpx solid rgba(231, 226, 225, 0.82);
}

.skip-triangle-next {
  border-left: 12rpx solid rgba(231, 226, 225, 0.82);
}

.skip-triangle.overlap {
  margin-left: -3rpx;
  margin-right: -3rpx;
}

.pause-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.pause-bar {
  width: 7rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #33120d;
}

.play-icon-shape {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #33120d;
}
