<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll melody-page">
    <view class="melody-stage">
      <image class="melody-stage-bg" src="{{currentTrack.cover}}" mode="aspectFill"></image>
      <view class="melody-stage-mask"></view>

      <view class="melody-stage-copy">
        <text class="eyebrow">Music Pairing</text>
        <text class="display-title">Quiet Sessions</text>
        <text class="melody-stage-subtitle">{{wine.moodLine}}</text>
      </view>
    </view>

    <view class="section-card section-card--paper melody-player-card">
      <view class="player-top">
        <image
          class="player-cover {{isPlaying ? 'player-cover--playing' : ''}}"
          src="{{currentTrack.cover}}"
          mode="aspectFill"
        ></image>

        <view class="player-copy">
          <text class="paper-eyebrow">{{currentTrack.mood}}</text>
          <text class="paper-title paper-title--small">{{currentTrack.title}}</text>
          <text class="paper-copy">{{currentTrack.description}}</text>
        </view>
      </view>

      <view class="progress-wrap">
        <view class="progress-rail">
          <view class="progress-fill" style="width: {{progress}}%;"></view>
        </view>

        <view class="progress-labels">
          <text>{{currentTimeLabel}}</text>
          <text>{{durationLabel}}</text>
        </view>
      </view>

      <view class="control-row">
        <button class="control-key" bindtap="playPrev">Prev</button>
        <button class="control-play" bindtap="togglePlayback">
          {{isPlaying ? 'PAUSE' : 'PLAY'}}
        </button>
        <button class="control-key" bindtap="playNext">Next</button>
      </view>
    </view>

    <view class="section-card melody-note">
      <text class="eyebrow">Current Pour</text>
      <text class="section-heading melody-note-title">{{wine.title}}</text>
      <text class="muted-copy">{{wine.quote}}</text>
    </view>

    <view class="track-list">
      <view
        class="section-card track-card {{currentTrackIndex === index ? 'track-card--active' : ''}}"
        wx:for="{{tracks}}"
        wx:key="id"
        wx:for-index="index"
        data-index="{{index}}"
        bindtap="selectTrack"
      >
        <text class="track-no">0{{index + 1}}</text>
        <image class="track-thumb" src="{{item.cover}}" mode="aspectFill"></image>
        <view class="track-copy">
          <text class="track-mood">{{item.mood}}</text>
          <text class="track-title">{{item.title}}</text>
          <text class="track-description">{{item.description}}</text>
        </view>
        <text class="track-time">{{item.durationLabel}}</text>
      </view>
    </view>

    <view class="tabbar-gap"></view>
    <editorial-tabbar active="melody"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator class="ghost-button" url="/pages/redeem/index">Back To Entry</navigator>
  </view>
</view>
