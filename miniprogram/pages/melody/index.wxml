<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll melody-page">
    <image class="melody-bg" src="/assets/images/melody-phone-bg.jpg" mode="aspectFill"></image>
    <view class="melody-bg-shadow"></view>
    <view class="melody-bg-overlay"></view>

    <view class="melody-topbar">
      <button class="topbar-button">
        <image class="topbar-icon" src="/assets/icons/menu.svg" mode="aspectFit"></image>
      </button>
      <text class="topbar-title">THE CURATOR</text>
      <button class="topbar-button">
        <image class="topbar-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
      </button>
    </view>

    <view class="melody-stage">
      <view class="cover-shell">
        <image class="cover-image" src="/assets/images/melody-phone-cover.jpg" mode="aspectFill"></image>
        <view class="cover-core"></view>
      </view>

      <text class="eyebrow melody-kicker">AMBIENT PAIRING</text>
      <text class="display-title melody-title">Vintage Noir</text>
      <text class="muted-copy melody-description">
        Soft cello and distant rain, curated for an aged Cabernet Sauvignon.
      </text>

      <view class="progress-wrap">
        <view class="progress-rail">
          <view class="progress-fill" style="width: {{progress}}%;"></view>
        </view>
        <view class="progress-labels">
          <text>{{currentTimeLabel}}</text>
          <text>{{durationLabel}}</text>
        </view>
      </view>

      <view class="control-row">
        <view class="control-side control-touch" bindtap="playPrev" hover-class="control-touch-active">
          <view class="skip-icon skip-prev">
            <view class="skip-bar"></view>
            <view class="skip-triangle skip-triangle-prev"></view>
            <view class="skip-triangle skip-triangle-prev overlap"></view>
          </view>
        </view>
        <view class="control-main control-touch" bindtap="togglePlayback" hover-class="control-touch-active">
          <view wx:if="{{isPlaying}}" class="pause-icon">
            <view class="pause-bar"></view>
            <view class="pause-bar"></view>
          </view>
          <view wx:else class="play-icon-shape"></view>
        </view>
        <view class="control-side control-touch" bindtap="playNext" hover-class="control-touch-active">
          <view class="skip-icon skip-next">
            <view class="skip-bar"></view>
            <view class="skip-triangle skip-triangle-next"></view>
            <view class="skip-triangle skip-triangle-next overlap"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="tabbar-gap" wx:if="{{!trackId}}"></view>
    <editorial-tabbar wx:if="{{!trackId}}" active="melody"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator wx:if="{{entryScope === 'exclusive'}}" class="ghost-button" url="/pages/redeem/index">返回扫码页</navigator>
    <navigator wx:elif="{{entryScope === 'member'}}" class="ghost-button" url="/pages/member/index">返回会员中心</navigator>
    <navigator wx:else class="ghost-button" url="/pages/home/index">返回首页</navigator>
  </view>
</view>
