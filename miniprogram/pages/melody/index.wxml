<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll melody-page">
    <view class="melody-stage">
      <image class="melody-stage-bg" src="{{currentTrack.cover}}" mode="aspectFill"></image>
      <view class="melody-stage-mask"></view>
      <view class="melody-stage-copy">
        <text class="eyebrow">CELLAR SCORE</text>
        <text class="display-title">{{currentTrack.cnTitle}}</text>
        <text class="muted-copy line-clamp-2">{{currentTrack.description}}</text>
      </view>
    </view>

    <view class="paper-panel player-card">
      <view class="player-head">
        <image class="player-cover" src="{{currentTrack.cover}}" mode="aspectFill"></image>
        <view class="player-copy">
          <text class="eyebrow player-kicker">{{wine.name}}</text>
          <text class="section-title">{{currentTrack.title}}</text>
          <text class="micro-copy line-clamp-2">{{wine.moodLine}}</text>
        </view>
      </view>

      <view class="progress-wrap">
        <view class="progress-rail">
          <view class="progress-fill" style="width: {{progress}}%;"></view>
        </view>
        <view class="progress-labels">
          <text>{{currentTimeLabel}}</text>
          <text>{{durationLabel}}</text>
        </view>
      </view>

      <view class="control-row">
        <button class="ghost-button player-mini" bindtap="playPrev">上一曲</button>
        <button class="primary-button player-main" bindtap="togglePlayback">{{isPlaying ? '暂停' : '播放'}}</button>
        <button class="ghost-button player-mini" bindtap="playNext">下一曲</button>
      </view>

      <view wx:if="{{gateMessage}}" class="gate-panel">
        <text class="micro-copy line-clamp-2">{{gateMessage}}</text>
        <view class="gate-actions">
          <button wx:if="{{entryScope === 'exclusive'}}" class="soft-button gate-button" bindtap="openDetail">查看酒款</button>
          <button wx:else class="soft-button gate-button" bindtap="openMember">会员权益</button>
          <button class="ghost-button gate-button" bindtap="unlockCurrentTrack">单曲解锁</button>
        </view>
      </view>
    </view>

    <view class="track-list">
      <view
        class="track-item {{currentTrackIndex === index ? 'is-active' : ''}}"
        wx:for="{{tracks}}"
        wx:key="id"
        wx:for-index="index"
        data-index="{{index}}"
        bindtap="selectTrack"
      >
        <text class="track-no">0{{index + 1}}</text>
        <view class="track-main">
          <text class="track-name">{{item.cnTitle}}</text>
          <text class="micro-copy">{{item.access.canPlayFull ? '完整' : '试听'}}</text>
        </view>
        <text class="track-time">{{item.durationLabel}}</text>
      </view>
    </view>

    <view class="tabbar-gap" wx:if="{{!trackId}}"></view>
    <editorial-tabbar wx:if="{{!trackId}}" active="melody"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator wx:if="{{entryScope === 'exclusive'}}" class="ghost-button" url="/pages/redeem/index">返回扫码页</navigator>
    <navigator wx:elif="{{entryScope === 'member'}}" class="ghost-button" url="/pages/member/index">返回会员中心</navigator>
    <navigator wx:else class="ghost-button" url="/pages/home/index">返回首页</navigator>
  </view>
</view>
