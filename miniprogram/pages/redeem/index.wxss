.redeem-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.redeem-bg,
.redeem-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.redeem-mask {
  background:
    linear-gradient(180deg, rgba(8, 6, 5, 0.22) 0%, rgba(8, 6, 5, 0.92) 100%),
    radial-gradient(circle at 50% 14%, rgba(245, 219, 176, 0.22), rgba(245, 219, 176, 0));
}

.redeem-copy {
  position: relative;
  z-index: 2;
  padding: 132rpx 32rpx 26rpx;
}

.redeem-title {
  margin: 10rpx 0 12rpx;
}

.redeem-subtitle {
  max-width: 420rpx;
}

.redeem-card {
  position: relative;
  z-index: 2;
  margin: 200rpx 22rpx 0;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.12);
  background:
    linear-gradient(180deg, rgba(16, 12, 11, 0.82), rgba(10, 8, 8, 0.88)),
    rgba(16, 12, 11, 0.82);
  backdrop-filter: blur(22rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.redeem-card-title {
  margin-top: -6rpx;
}

.code-input-area {
  margin: 12rpx 0 8rpx;
}

.digit-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.digit-box {
  width: 88rpx;
  height: 104rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(214, 177, 124, 0.3);
  background: rgba(16, 12, 11, 0.6);
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--gold-strong, #d6b17c);
  caret-color: var(--gold, #c9a96e);
}

.digit-filled {
  border-color: rgba(214, 177, 124, 0.6);
}

.loading-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.loading-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--gold);
  animation: pulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.success-seal {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 177, 124, 0.6);
  background: rgba(214, 177, 124, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-seal-text {
  color: var(--gold-strong);
  letter-spacing: 0.18em;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.24;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.3);
  }
}
