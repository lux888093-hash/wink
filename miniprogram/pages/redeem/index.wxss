.redeem-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.redeem-bg,
.redeem-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.redeem-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.22) 0%, rgba(24, 21, 18, 0) 48%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.22) 0%, rgba(18, 14, 13, 0.86) 100%);
}

.redeem-copy {
  position: relative;
  z-index: 2;
  padding: 132rpx 32rpx 26rpx;
}

.redeem-title {
  margin: 10rpx 0 12rpx;
}

.redeem-subtitle {
  max-width: 420rpx;
}

.redeem-card {
  position: relative;
  z-index: 2;
  margin: 200rpx 22rpx 0;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.18) 0%, rgba(29, 23, 21, 0) 58%),
    linear-gradient(180deg, rgba(44, 38, 32, 0.82), rgba(18, 14, 13, 0.9)),
    var(--panel-strong);
  backdrop-filter: blur(22rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.redeem-card-title {
  margin-top: -6rpx;
}

.code-input-area {
  margin: 12rpx 0 8rpx;
}

.digit-row {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.digit-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 104rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(220, 185, 133, 0.32);
  background: rgba(24, 21, 18, 0.62);
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--gold-strong, #d6b17c);
  caret-color: var(--gold, #c9a96e);
}

.digit-filled {
  border-color: rgba(239, 208, 155, 0.62);
}

.digit-active {
  border-color: rgba(239, 208, 155, 0.82);
  background: rgba(220, 185, 133, 0.1);
}

.code-hidden-input {
  position: fixed;
  left: -1000rpx;
  top: 0;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  color: transparent;
  caret-color: transparent;
}

.loading-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.loading-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--gold);
  animation: pulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.success-seal {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  border: 2rpx solid rgba(239, 208, 155, 0.62);
  background: rgba(220, 185, 133, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-seal-text {
  color: var(--gold-strong);
  letter-spacing: 0;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.24;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.3);
  }
}
