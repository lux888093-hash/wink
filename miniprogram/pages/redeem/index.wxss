.redeem-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.redeem-bg,
.redeem-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.redeem-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.22) 0%, rgba(24, 21, 18, 0) 48%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.22) 0%, rgba(18, 14, 13, 0.86) 100%);
}

.redeem-copy {
  position: relative;
  z-index: 2;
  padding: 132rpx 32rpx 26rpx;
}

.redeem-title {
  margin: 10rpx 0 12rpx;
}

.redeem-subtitle {
  max-width: 420rpx;
}

.redeem-card {
  position: relative;
  z-index: 2;
  margin: 200rpx 22rpx 0;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.18) 0%, rgba(29, 23, 21, 0) 58%),
    linear-gradient(180deg, rgba(44, 38, 32, 0.82), rgba(18, 14, 13, 0.9)),
    var(--panel-strong);
  backdrop-filter: blur(22rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.redeem-card-title {
  margin-top: -6rpx;
}

.redeem-card-success {
  margin-top: 176rpx;
  padding: 34rpx 28rpx 32rpx;
  align-items: center;
  text-align: center;
  gap: 16rpx;
  border-color: rgba(239, 208, 155, 0.18);
  background:
    linear-gradient(152deg, rgba(93, 31, 37, 0.32) 0%, rgba(29, 23, 21, 0) 48%),
    linear-gradient(180deg, rgba(38, 32, 28, 0.9), rgba(18, 14, 13, 0.96)),
    var(--panel-strong);
  box-shadow:
    0 24rpx 56rpx rgba(18, 12, 11, 0.3),
    inset 0 1rpx 0 rgba(255, 246, 235, 0.06);
}

.redeem-card-success .redeem-card-title {
  margin-top: -2rpx;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.12;
}

.redeem-card-success .muted-copy {
  max-width: 480rpx;
  text-align: center;
}

.code-input-area {
  margin: 12rpx 0 8rpx;
}

.digit-row {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.digit-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 104rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(220, 185, 133, 0.32);
  background: rgba(24, 21, 18, 0.62);
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--gold-strong, #d6b17c);
  caret-color: var(--gold, #c9a96e);
}

.digit-filled {
  border-color: rgba(239, 208, 155, 0.62);
}

.digit-active {
  border-color: rgba(239, 208, 155, 0.82);
  background: rgba(220, 185, 133, 0.1);
}

.code-hidden-input {
  position: fixed;
  left: -1000rpx;
  top: 0;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  color: transparent;
  caret-color: transparent;
}

.loading-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.loading-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--gold);
  animation: pulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.success-stage {
  width: 100%;
  margin-top: 8rpx;
  padding: 10rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.success-mark {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(247, 236, 221, 0.1), rgba(220, 185, 133, 0.04));
  box-shadow:
    inset 0 0 0 1rpx rgba(239, 208, 155, 0.22),
    0 18rpx 42rpx rgba(42, 16, 19, 0.3);
}

.success-mark::before {
  content: "";
  position: absolute;
  inset: 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(239, 208, 155, 0.18);
}

.success-mark-core {
  position: relative;
  z-index: 1;
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #efd09b 0%, #b98c52 100%);
  box-shadow:
    0 10rpx 26rpx rgba(104, 76, 45, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
  animation: success-pop 0.42s cubic-bezier(0.2, 0.9, 0.25, 1.08) both;
}

.success-mark-icon {
  color: #241b14;
  font-size: 52rpx;
  font-weight: 600;
  line-height: 1;
  transform: translateY(-2rpx);
}

.success-progress {
  width: 190rpx;
  height: 4rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.13);
}

.success-progress-fill {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #7a2a31 0%, #dcc08a 100%);
  transform-origin: left center;
  animation: success-progress 0.9s ease both;
}

.success-note {
  display: block;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.45;
  letter-spacing: 0;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.24;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.3);
  }
}

@keyframes success-pop {
  0% {
    opacity: 0;
    transform: scale(0.76);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes success-progress {
  0% {
    transform: scaleX(0);
  }
  100% {
    transform: scaleX(1);
  }
}
