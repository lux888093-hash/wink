.order-page {
  padding-top: 8rpx;
  padding-bottom: 300rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.order-flow {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-topbar,
.address-editor-topbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 82rpx;
  padding: 0 6rpx;
}

.order-back,
.order-topbar-gap {
  width: 72rpx;
  flex-shrink: 0;
}

.order-back {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  color: var(--ink);
  font-size: 52rpx;
  line-height: 1;
}

.order-topbar-title,
.address-editor-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: -0.02em;
}

.order-card {
  overflow: hidden;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(20, 15, 14, 0.92), rgba(13, 10, 9, 0.94)),
    rgba(13, 10, 9, 0.94);
  border: 1rpx solid rgba(226, 199, 159, 0.06);
  box-shadow: none;
}

.order-address-card {
  padding: 22rpx 22rpx 24rpx;
}

.order-address-region {
  display: block;
  color: var(--ink-soft);
  font-size: 17rpx;
  line-height: 1.5;
}

.order-address-main-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
}

.order-address-main {
  flex: 1;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.26;
  letter-spacing: -0.02em;
}

.order-chevron {
  color: var(--ink-faint);
  font-size: 30rpx;
  line-height: 1;
}

.order-address-contact {
  display: block;
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 18rpx;
}

.order-address-card.is-empty .order-address-main {
  color: var(--ink-soft);
  font-size: 22rpx;
  font-weight: 600;
}

.order-delivery-card {
  padding: 24rpx 24rpx 12rpx;
}

.order-fee-info {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(246, 239, 231, 0.4);
  color: var(--ink-soft);
  font-size: 16rpx;
  line-height: 26rpx;
  text-align: center;
  flex-shrink: 0;
}

.order-product-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 4rpx 0 20rpx;
}

.order-product-image {
  width: 102rpx;
  height: 102rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: rgba(244, 235, 225, 0.08);
}

.order-product-info {
  flex: 1;
  min-width: 0;
}

.order-product-title {
  color: var(--ink);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.34;
}

.order-product-spec {
  display: block;
  margin-top: 6rpx;
  color: var(--ink-soft);
  font-size: 16rpx;
  line-height: 1.45;
}

.order-product-count {
  flex-shrink: 0;
  color: var(--ink-soft);
  font-size: 16rpx;
  line-height: 1.4;
  padding-top: 6rpx;
}

.order-fee-list {
  border-top: 1rpx solid rgba(226, 199, 159, 0.08);
}

.order-fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 82rpx;
}

.order-fee-remark-row {
  border-top: 1rpx solid rgba(226, 199, 159, 0.08);
}

.order-fee-label-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.order-fee-label,
.order-fee-value {
  color: var(--ink);
  font-size: 18rpx;
}

.order-fee-placeholder {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-fee-placeholder-text {
  color: var(--ink-faint);
  font-size: 18rpx;
}

.order-subtotal-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 16rpx 0 6rpx;
  border-top: 1rpx solid rgba(226, 199, 159, 0.08);
}

.order-subtotal-label {
  color: var(--ink);
  font-size: 18rpx;
}

.order-subtotal-value {
  color: #ea3b35;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.order-pay-stack {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 110;
  background: none;
  border: 0;
  box-shadow: none;
}

.order-pay-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 92rpx;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    linear-gradient(180deg, rgba(23, 17, 16, 0.96), rgba(13, 10, 9, 0.98)),
    rgba(13, 10, 9, 0.98);
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.order-pay-right-group {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-left: auto;
  width: auto;
  max-width: 100%;
}

.order-pay-summary {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
  flex-wrap: nowrap;
  flex-shrink: 1;
  min-width: 0;
}

.order-pay-summary-text {
  color: var(--ink-soft);
  font-size: 16rpx;
}

.order-pay-summary-value {
  color: #ea3b35;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.02em;
}

.order-pay-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 98rpx;
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 18rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.address-screen {
  position: fixed;
  inset: 0;
  z-index: 220;
}

.address-sheet-shell,
.address-editor-shell {
  position: absolute;
  inset: 0;
}

.address-sheet-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(5, 4, 4, 0.52);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}

.address-sheet-panel,
.address-editor-panel {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 16rpx 18rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(18, 14, 13, 0.98), rgba(10, 8, 8, 0.995)),
    rgba(11, 8, 8, 0.995);
}

.address-sheet-panel {
  justify-content: flex-end;
  padding: 200rpx 0 0;
  background: transparent;
}

.address-sheet-surface {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 200rpx);
  padding: 16rpx 18rpx 24rpx;
  border-radius: 30rpx 30rpx 0 0;
  background:
    linear-gradient(180deg, rgba(18, 14, 13, 0.98), rgba(10, 8, 8, 0.995)),
    rgba(11, 8, 8, 0.995);
  box-shadow: none;
  border-top: 1rpx solid rgba(226, 199, 159, 0.08);
}

.address-sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  margin-bottom: 10rpx;
  position: relative;
}

.address-sheet-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.address-sheet-close {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ink-soft);
  font-size: 38rpx;
  line-height: 1;
  padding: 10rpx;
}

.address-sheet-list {
  flex: 1;
  min-height: 0;
}

.address-sheet-card {
  padding: 20rpx 18rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(244, 235, 225, 0.035);
  border: 1rpx solid rgba(226, 199, 159, 0.06);
  box-shadow: none;
  margin-bottom: 12rpx;
}

.address-sheet-card.is-active {
  border-color: rgba(231, 200, 150, 0.16);
  background: rgba(231, 200, 150, 0.08);
  box-shadow: none;
}

.address-sheet-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.address-sheet-region {
  flex: 1;
  color: var(--ink-soft);
  font-size: 16rpx;
  line-height: 1.45;
}

.address-sheet-badge {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  background: rgba(84, 160, 255, 0.14);
  color: #79b7ff;
  font-size: 16rpx;
}

.address-sheet-main-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 10rpx;
}

.address-sheet-main {
  flex: 1;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.34;
  letter-spacing: -0.01em;
}

.address-sheet-edit {
  flex-shrink: 0;
  color: var(--gold-strong);
  font-size: 16rpx;
  line-height: 1.4;
  padding-top: 2rpx;
}

.address-sheet-contact {
  display: block;
  margin-top: 12rpx;
  color: var(--ink-soft);
  font-size: 16rpx;
}

.address-sheet-empty {
  padding: 72rpx 20rpx;
  text-align: center;
}

.address-sheet-empty-title {
  display: block;
  color: var(--ink-soft);
  font-size: 18rpx;
  font-weight: 600;
}

.address-sheet-action,
.address-editor-save {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 74rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 18rpx;
  font-weight: 700;
}

.address-editor-card {
  margin-top: 10rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 235, 225, 0.035);
  border: 1rpx solid rgba(226, 199, 159, 0.06);
}

.address-editor-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 84rpx;
  border-bottom: 1rpx solid rgba(226, 199, 159, 0.08);
}

.address-editor-row:last-child {
  border-bottom: 0;
}

.address-editor-row-area {
  align-items: flex-start;
  padding: 18rpx 0;
}

.address-editor-label {
  width: 98rpx;
  flex-shrink: 0;
  color: var(--ink);
  font-size: 18rpx;
  line-height: 1.4;
}

.address-editor-area {
  flex: 1;
  min-width: 0;
}

.address-editor-phone {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.address-editor-phone-code {
  flex-shrink: 0;
  padding-right: 16rpx;
  border-right: 1rpx solid rgba(226, 199, 159, 0.12);
  color: var(--ink);
  font-size: 18rpx;
  line-height: 1;
}

.address-editor-input {
  width: 100%;
  min-height: 64rpx;
  color: var(--ink);
  font-size: 18rpx;
  line-height: 64rpx;
}

.address-editor-placeholder {
  color: rgba(246, 239, 231, 0.42);
}

.address-editor-input-detail {
  margin-top: 4rpx;
}

.address-editor-current {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(244, 235, 225, 0.06);
}

.address-editor-current-copy {
  flex: 1;
  min-width: 0;
}

.address-editor-current-title {
  display: block;
  color: var(--ink);
  font-size: 17rpx;
  font-weight: 600;
  line-height: 1.4;
}

.address-editor-current-sub {
  display: block;
  margin-top: 4rpx;
  color: var(--ink-soft);
  font-size: 15rpx;
  line-height: 1.5;
}

.address-editor-current-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(231, 200, 150, 0.4);
  color: var(--gold-strong);
  font-size: 16rpx;
}

.address-editor-save {
  margin-top: auto;
}

.success-panel {
  padding: 28rpx 24rpx 30rpx;
}

.success-seal {
  width: 118rpx;
  height: 118rpx;
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.28);
  background: rgba(214, 177, 124, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-seal-text {
  color: var(--gold-strong);
  font-size: 18rpx;
  letter-spacing: 0.24em;
}

.success-title {
  margin: 14rpx 0 10rpx;
}

.success-meta {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 22rpx 0 26rpx;
}

.success-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.success-meta-label {
  color: var(--ink-faint);
  font-size: 18rpx;
}

.success-meta-value {
  color: var(--ink);
  font-size: 20rpx;
}
