.order-page {
  padding-top: 10rpx;
  padding-bottom: 320rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.order-flow {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-topbar,
.address-editor-topbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 6rpx;
}

.order-back,
.order-topbar-gap {
  width: 72rpx;
  flex-shrink: 0;
}

.order-back {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  color: var(--ink);
  font-size: 56rpx;
  line-height: 1;
}

.order-topbar-title,
.address-editor-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
}

.order-card {
  overflow: hidden;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(44, 38, 32, 0.9), rgba(31, 27, 23, 0.94)),
    var(--panel-strong);
  border: 1rpx solid var(--panel-line);
  box-shadow: none;
}

.order-address-card {
  padding: 26rpx 26rpx 28rpx;
}

.order-address-region {
  display: block;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.order-address-main-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.order-address-main {
  flex: 1;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.22;
  letter-spacing: 0;
}

.order-chevron {
  color: var(--ink-faint);
  font-size: 34rpx;
  line-height: 1;
}

.order-address-contact {
  display: block;
  margin-top: 16rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.order-address-card.is-empty .order-address-main {
  color: var(--ink-soft);
  font-size: 26rpx;
  font-weight: 600;
}

.order-delivery-card {
  padding: 28rpx 28rpx 16rpx;
}

.order-fee-info {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(246, 239, 231, 0.4);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  flex-shrink: 0;
}

.order-product-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 4rpx 0 24rpx;
}

.order-product-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: rgba(247, 236, 221, 0.09);
}

.order-product-info {
  flex: 1;
  min-width: 0;
}

.order-product-title {
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.3;
}

.order-product-spec {
  display: block;
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 21rpx;
  line-height: 1.45;
}

.order-product-count {
  flex-shrink: 0;
  color: var(--ink-soft);
  font-size: 21rpx;
  line-height: 1.4;
  padding-top: 6rpx;
}

.order-fee-list {
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
}

.order-fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 92rpx;
}

.order-fee-remark-row {
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
}

.order-fee-label-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.order-fee-label,
.order-fee-value {
  color: var(--ink);
  font-size: 22rpx;
}

.order-fee-placeholder {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-fee-placeholder-text {
  color: var(--ink-faint);
  font-size: 21rpx;
}

.order-subtotal-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 10rpx;
  padding: 18rpx 0 8rpx;
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
}

.order-subtotal-label {
  color: var(--ink);
  font-size: 22rpx;
}

.order-subtotal-value {
  color: var(--gold-strong);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.order-pay-stack {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  z-index: 110;
  background: none;
  border: 0;
  box-shadow: none;
}

.order-pay-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 102rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(180deg, rgba(38, 32, 27, 0.96), rgba(24, 21, 18, 0.98)),
    rgba(24, 21, 18, 0.98);
  box-shadow: 0 12rpx 26rpx rgba(18, 15, 12, 0.16);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.order-pay-right-group {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-left: auto;
  width: auto;
  max-width: 100%;
}

.order-pay-summary {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
  flex-wrap: nowrap;
  flex-shrink: 1;
  min-width: 0;
}

.order-pay-summary-text {
  color: var(--ink-soft);
  font-size: 20rpx;
}

.order-pay-summary-value {
  color: var(--gold-strong);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0;
}

.order-pay-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 122rpx;
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ead0a3 0%, #b8874c 100%);
  color: #241b14;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.address-screen {
  position: fixed;
  inset: 0;
  z-index: 220;
}

.address-sheet-shell,
.address-editor-shell {
  position: absolute;
  inset: 0;
}

.address-sheet-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(24, 21, 18, 0.52);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}

.address-sheet-panel,
.address-editor-panel {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 16rpx 18rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(38, 32, 27, 0.98), rgba(24, 21, 18, 0.995)),
    rgba(24, 21, 18, 0.995);
}

.address-sheet-panel {
  justify-content: flex-end;
  padding: 200rpx 0 0;
  background: transparent;
}

.address-sheet-surface {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 200rpx);
  padding: 18rpx 24rpx 28rpx;
  border-radius: 30rpx 30rpx 0 0;
  background:
    linear-gradient(180deg, rgba(38, 32, 27, 0.98), rgba(24, 21, 18, 0.995)),
    rgba(24, 21, 18, 0.995);
  box-shadow: none;
  border-top: 1rpx solid var(--panel-line);
}

.address-sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.address-sheet-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.address-sheet-close {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ink-soft);
  font-size: 44rpx;
  line-height: 1;
  padding: 10rpx;
}

.address-sheet-list {
  flex: 1;
  min-height: 0;
}

.address-sheet-card {
  padding: 24rpx 22rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(247, 236, 221, 0.055);
  border: 1rpx solid rgba(220, 185, 133, 0.1);
  box-shadow: none;
  margin-bottom: 12rpx;
}

.address-sheet-card.is-active {
  border-color: rgba(239, 208, 155, 0.22);
  background: rgba(239, 208, 155, 0.1);
  box-shadow: none;
}

.address-sheet-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.address-sheet-region {
  flex: 1;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.45;
}

.address-sheet-badge {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(84, 160, 255, 0.14);
  color: #79b7ff;
  font-size: 20rpx;
}

.address-sheet-main-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 12rpx;
}

.address-sheet-main {
  flex: 1;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.25;
  letter-spacing: 0;
}

.address-sheet-edit {
  flex-shrink: 0;
  color: var(--gold-strong);
  font-size: 22rpx;
  line-height: 1.4;
  padding-top: 2rpx;
}

.address-sheet-contact {
  display: block;
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.address-sheet-empty {
  padding: 72rpx 20rpx;
  text-align: center;
}

.address-sheet-empty-title {
  display: block;
  color: var(--ink-soft);
  font-size: 22rpx;
  font-weight: 600;
}

.address-sheet-action,
.address-editor-save {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ead0a3 0%, #b8874c 100%);
  color: #241b14;
  font-size: 24rpx;
  font-weight: 700;
}

.address-editor-card {
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(247, 236, 221, 0.055);
  border: 1rpx solid rgba(220, 185, 133, 0.1);
}

.address-editor-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 98rpx;
  border-bottom: 1rpx solid rgba(220, 185, 133, 0.1);
}

.address-editor-row:last-child {
  border-bottom: 0;
}

.address-editor-row-area {
  align-items: flex-start;
  padding: 22rpx 0;
}

.address-editor-label {
  width: 116rpx;
  flex-shrink: 0;
  color: var(--ink);
  font-size: 22rpx;
  line-height: 1.4;
}

.address-editor-area {
  flex: 1;
  min-width: 0;
}

.address-editor-phone {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.address-editor-phone-code {
  flex-shrink: 0;
  padding-right: 18rpx;
  border-right: 1rpx solid rgba(220, 185, 133, 0.14);
  color: var(--ink);
  font-size: 22rpx;
  line-height: 1;
}

.address-editor-input {
  width: 100%;
  min-height: 72rpx;
  color: var(--ink);
  font-size: 22rpx;
  line-height: 72rpx;
}

.address-editor-placeholder {
  color: rgba(246, 239, 231, 0.42);
}

.address-editor-input-detail {
  margin-top: 4rpx;
}

.address-editor-current {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(247, 236, 221, 0.08);
}

.address-editor-current-copy {
  flex: 1;
  min-width: 0;
}

.address-editor-current-title {
  display: block;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
}

.address-editor-current-sub {
  display: block;
  margin-top: 4rpx;
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.5;
}

.address-editor-current-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 94rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(239, 208, 155, 0.42);
  color: var(--gold-strong);
  font-size: 20rpx;
}

.address-editor-save {
  margin-top: auto;
}

.success-panel {
  padding: 28rpx 24rpx 30rpx;
}

.success-seal {
  width: 118rpx;
  height: 118rpx;
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(220, 185, 133, 0.3);
  background: rgba(220, 185, 133, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-seal-text {
  color: var(--gold-strong);
  font-size: 20rpx;
  letter-spacing: 0;
}

.success-title {
  margin: 14rpx 0 10rpx;
}

.success-meta {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 22rpx 0 26rpx;
}

.success-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.success-meta-label {
  color: var(--ink-faint);
  font-size: 21rpx;
}

.success-meta-value {
  color: var(--ink);
  font-size: 22rpx;
}
