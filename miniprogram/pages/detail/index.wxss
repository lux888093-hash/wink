.detail-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-paper {
  padding: 24rpx;
}

.detail-kicker {
  color: rgba(63, 42, 20, 0.7);
}

.detail-title {
  margin: 12rpx 0 10rpx;
}

.detail-chip-row {
  margin: 16rpx 0;
}

.detail-quote {
  position: relative;
  margin-top: 18rpx;
  padding-left: 30rpx;
  border-left: 1rpx solid rgba(63, 42, 20, 0.16);
}

.detail-quote-mark {
  position: absolute;
  left: 8rpx;
  top: -2rpx;
  color: rgba(63, 42, 20, 0.28);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 44rpx;
}

.detail-quote-text {
  color: rgba(43, 33, 27, 0.82);
  font-size: 22rpx;
  line-height: 1.7;
}

.detail-visual {
  min-height: 420rpx;
  border-radius: 34rpx;
}

.detail-visual-bg,
.detail-visual-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.detail-visual-mask {
  background:
    linear-gradient(180deg, rgba(8, 6, 5, 0.08) 0%, rgba(8, 6, 5, 0.82) 100%),
    radial-gradient(circle at 82% 14%, rgba(245, 219, 176, 0.18), rgba(245, 219, 176, 0));
}

.detail-bottle {
  position: absolute;
  right: 24rpx;
  bottom: 18rpx;
  width: 240rpx;
  height: 360rpx;
  z-index: 2;
}

.note-panel,
.tech-panel {
  padding: 24rpx;
}

.note-item {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(214, 177, 124, 0.1);
}

.note-item:first-child {
  padding-top: 0;
  border-top: 0;
}

.note-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.note-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 26rpx;
}

.note-meter {
  color: var(--gold);
}

.tech-item {
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(63, 42, 20, 0.1);
}

.tech-item:first-child {
  border-top: 0;
}

.tech-label {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(63, 42, 20, 0.56);
  font-size: 16rpx;
}

.tech-value {
  display: block;
  color: var(--paper-ink);
  font-size: 22rpx;
  line-height: 1.6;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
}

.detail-action {
  flex: 1;
}
