.detail-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 24rpx 212rpx;
  background:
    linear-gradient(180deg, rgba(37, 21, 21, 0.9) 0%, rgba(23, 18, 17, 1) 34%, rgba(18, 16, 15, 1) 100%),
    var(--bg);
}

.detail-hero {
  position: relative;
  min-height: 880rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  background: var(--bg);
}

.detail-hero-image,
.detail-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.detail-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.22) 0%, rgba(24, 21, 18, 0) 48%),
    linear-gradient(180deg, rgba(16, 13, 12, 0.02) 0%, rgba(42, 16, 19, 0.14) 40%, rgba(18, 14, 13, 0.94) 100%),
    linear-gradient(90deg, rgba(18, 14, 13, 0.66) 0%, rgba(24, 21, 18, 0.1) 54%, rgba(18, 14, 13, 0.3) 100%);
}

.detail-hero-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 150rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 540rpx;
}

.detail-kicker,
.detail-fact-label,
.detail-statement-kicker,
.detail-section-kicker,
.detail-note-icon {
  display: block;
  color: rgba(231, 200, 150, 0.78);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.detail-title {
  display: block;
  max-width: 560rpx;
  margin: 16rpx 0 12rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 64rpx;
  font-weight: 600;
  line-height: 1.02;
  letter-spacing: 0;
}

.detail-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.36;
  letter-spacing: 0;
}

.detail-facts {
  display: flex;
  gap: 0;
  position: relative;
  z-index: 3;
  margin: -112rpx -24rpx 0;
  padding: 26rpx 24rpx 50rpx;
  border-top: 1rpx solid rgba(220, 185, 133, 0.18);
  background:
    linear-gradient(180deg, rgba(23, 18, 17, 0.14), rgba(23, 18, 17, 0.96) 46%, rgba(23, 18, 17, 1) 100%);
  backdrop-filter: blur(18rpx);
}

.detail-fact {
  flex: 1;
  min-width: 0;
  padding: 0 14rpx;
  border-left: 1rpx solid rgba(231, 200, 150, 0.14);
}

.detail-fact:first-child {
  border-left: 0;
  padding-left: 0;
}

.detail-fact:last-child {
  padding-right: 0;
}

.detail-fact-value {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.34;
  letter-spacing: 0;
}

.detail-statement {
  position: relative;
  margin: 0 -24rpx;
  min-height: 300rpx;
  padding: 52rpx 30rpx 58rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(220, 185, 133, 0.12), rgba(220, 185, 133, 0) 42%),
    linear-gradient(135deg, rgba(93, 31, 37, 0.24), rgba(93, 31, 37, 0) 58%),
    linear-gradient(180deg, rgba(31, 24, 21, 0.98), rgba(18, 14, 13, 1));
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
  border-bottom: 1rpx solid rgba(220, 185, 133, 0.08);
}

.detail-statement-copy {
  position: relative;
  flex: 1;
  min-width: 0;
}

.detail-statement-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.detail-statement-sub {
  color: rgba(255, 246, 235, 0.38);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: 0;
}

.detail-statement-title {
  display: block;
  max-width: 570rpx;
  color: rgba(255, 250, 242, 0.96);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.16;
  letter-spacing: 0;
}

.detail-statement-rule {
  width: 116rpx;
  height: 1rpx;
  margin: 24rpx 0 22rpx;
  background: linear-gradient(90deg, rgba(220, 192, 138, 0.76), rgba(220, 192, 138, 0));
}

.detail-statement-body {
  display: block;
  max-width: 570rpx;
  color: rgba(255, 246, 235, 0.72);
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.68;
  letter-spacing: 0;
}

.detail-poster {
  position: relative;
  min-height: 640rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  background: var(--bg-strong);
}

.detail-poster-image,
.detail-poster-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.detail-poster-mask {
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.16), rgba(24, 21, 18, 0) 52%),
    linear-gradient(180deg, rgba(18, 14, 13, 0.02), rgba(18, 14, 13, 0.82) 100%),
    linear-gradient(90deg, rgba(18, 14, 13, 0.5), rgba(18, 14, 13, 0.06) 54%, rgba(18, 14, 13, 0.34));
}

.detail-quote {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 38rpx;
  z-index: 2;
  padding-left: 26rpx;
  border-left: 1rpx solid rgba(220, 192, 138, 0.3);
}

.detail-quote-mark {
  position: absolute;
  left: 5rpx;
  top: -7rpx;
  color: rgba(220, 192, 138, 0.48);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 52rpx;
  line-height: 1;
}

.detail-quote-text {
  display: block;
  max-width: 570rpx;
  color: rgba(247, 239, 228, 0.84);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.58;
  letter-spacing: 0;
}

.detail-tasting,
.detail-service {
  margin: 0 -24rpx;
  padding: 46rpx 30rpx 50rpx;
  background:
    linear-gradient(135deg, rgba(93, 31, 37, 0.16) 0%, rgba(29, 23, 21, 0) 58%),
    linear-gradient(180deg, rgba(35, 28, 24, 0.96), rgba(18, 14, 13, 0.98));
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
}

.detail-note {
  margin-top: 20rpx;
  padding: 28rpx 0 30rpx;
  border-top: 1rpx solid rgba(220, 185, 133, 0.12);
}

.detail-note-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.detail-note-title {
  color: rgba(255, 255, 255, 0.94);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.detail-note-copy {
  display: block;
  color: rgba(255, 246, 235, 0.72);
  font-size: 23rpx;
  line-height: 1.58;
  letter-spacing: 0;
}

.detail-note-meter {
  height: 5rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.12);
}

.detail-note-meter-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #dcc08a 0%, #8f6a46 64%, #5d1f25 100%);
}

.detail-service {
  background:
    linear-gradient(90deg, rgba(220, 185, 133, 0.1), rgba(220, 185, 133, 0) 38%),
    linear-gradient(180deg, rgba(31, 24, 21, 0.98), rgba(18, 14, 13, 1));
}

.detail-service-row {
  display: flex;
  gap: 22rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(220, 185, 133, 0.12);
}

.detail-service-label {
  display: block;
  flex: none;
  width: 180rpx;
  color: rgba(231, 200, 150, 0.72);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.36;
  letter-spacing: 0;
}

.detail-service-value {
  display: block;
  flex: 1;
  min-width: 0;
  color: rgba(255, 246, 235, 0.76);
  font-size: 23rpx;
  line-height: 1.5;
  letter-spacing: 0;
}
