<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll detail-page">
    <view class="detail-hero">
      <view class="paper-panel detail-paper">
      <text class="eyebrow detail-kicker">{{wine.eyebrow}}</text>
      <text class="display-title detail-title">{{wine.name}}</text>
      <text class="muted-copy line-clamp-2">{{wine.subtitle}}</text>

        <view class="chip-row detail-chip-row">
          <text class="paper-chip">{{wine.region}}</text>
          <text class="paper-chip">{{wine.grapes}}</text>
          <text class="paper-chip">{{wine.abv}}</text>
        </view>

      <text class="muted-copy line-clamp-3">{{wine.overview}}</text>

        <view class="detail-quote">
          <text class="detail-quote-mark">“</text>
          <text class="detail-quote-text line-clamp-3">{{wine.quote}}</text>
        </view>
      </view>

      <view class="section-panel detail-visual">
        <image class="detail-visual-bg" src="{{wine.posterImage}}" mode="aspectFill"></image>
        <view class="detail-visual-mask"></view>
        <image class="detail-bottle" src="{{wine.bottleImage}}" mode="aspectFit"></image>
      </view>
    </view>

    <view class="section-panel note-panel">
      <text class="eyebrow">品鉴结构</text>
      <view class="note-item" wx:for="{{wine.tasting}}" wx:key="key">
        <view class="note-head">
          <text class="note-title">{{item.key}}</text>
          <text class="note-meter" wx:if="{{item.meter}}">{{item.meter}}</text>
        </view>
        <text class="muted-copy">{{item.text}}</text>
      </view>
    </view>

    <view class="paper-panel tech-panel">
      <text class="eyebrow detail-kicker">饮用建议</text>
      <view class="tech-item" wx:for="{{wine.technical}}" wx:key="label">
        <text class="tech-label">{{item.label}}</text>
        <text class="tech-value">{{item.value}}</text>
      </view>
    </view>

    <view class="detail-actions">
      <button class="primary-button detail-action" bindtap="openMelody">听配乐</button>
      <button wx:if="{{showMall}}" class="ghost-button detail-action" bindtap="openProduct">看礼盒</button>
    </view>

    <view wx:if="{{!showMall}}" class="tabbar-gap"></view>
    <editorial-tabbar wx:if="{{!showMall}}" active="detail"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator wx:if="{{entryScope === 'exclusive'}}" class="ghost-button" url="/pages/redeem/index">返回扫码页</navigator>
    <navigator wx:else class="ghost-button" url="/pages/home/index">返回首页</navigator>
  </view>
</view>
