<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll detail-page">
    <view class="detail-hero">
      <image class="detail-hero-image" src="{{wine.posterImage || wine.bottleImage}}" mode="aspectFill"></image>
      <view class="detail-hero-mask"></view>
      <view class="detail-hero-copy">
        <text class="detail-kicker">{{wine.region}}</text>
        <text class="detail-title">{{wine.name}}</text>
        <text class="detail-subtitle">{{wine.subtitle}}</text>
      </view>
    </view>

    <view class="detail-facts">
      <view class="detail-fact">
        <text class="detail-fact-label">产区</text>
        <text class="detail-fact-value">{{wine.region}}</text>
      </view>
      <view class="detail-fact">
        <text class="detail-fact-label">葡萄</text>
        <text class="detail-fact-value">{{wine.grapes}}</text>
      </view>
      <view class="detail-fact">
        <text class="detail-fact-label">酒精度</text>
        <text class="detail-fact-value">{{wine.abv}}</text>
      </view>
    </view>

    <view class="detail-statement">
      <view class="detail-statement-copy">
        <view class="detail-statement-head">
          <text class="detail-statement-kicker">酒款说明</text>
          <text class="detail-statement-sub">Tasting note</text>
        </view>
        <text class="detail-statement-title">风味与结构</text>
        <view class="detail-statement-rule"></view>
        <text class="detail-statement-body">{{wine.overview}}</text>
      </view>
    </view>

    <view class="detail-poster">
      <image class="detail-poster-image" src="{{wine.bottleImage || wine.posterImage}}" mode="aspectFill"></image>
      <view class="detail-poster-mask"></view>
      <view class="detail-quote">
        <text class="detail-quote-mark">“</text>
        <text class="detail-quote-text line-clamp-3">{{wine.quote}}</text>
      </view>
    </view>

    <view class="detail-tasting">
      <text class="detail-section-kicker">品鉴结构</text>
      <view class="detail-note" wx:for="{{wine.tasting}}" wx:key="key">
        <view class="detail-note-head">
          <text class="detail-note-icon">{{item.icon || item.key}}</text>
          <text class="detail-note-title">{{item.key}}</text>
        </view>
        <text class="detail-note-copy">{{item.text}}</text>
        <view wx:if="{{item.meter}}" class="detail-note-meter">
          <view class="detail-note-meter-fill" style="width: {{item.meter}}%;"></view>
        </view>
      </view>
    </view>

    <view class="detail-service">
      <text class="detail-section-kicker">饮用建议</text>
      <view class="detail-service-row" wx:for="{{wine.technical}}" wx:key="label">
        <text class="detail-service-label">{{item.label}}</text>
        <text class="detail-service-value">{{item.value}}</text>
      </view>
    </view>

    <view wx:if="{{!showMall}}" class="tabbar-gap"></view>
    <editorial-tabbar wx:if="{{!showMall}}" active="detail"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator wx:if="{{entryScope === 'exclusive'}}" class="ghost-button" url="/pages/redeem/index">返回提取码页</navigator>
    <navigator wx:else class="ghost-button" url="/pages/home/index">返回首页</navigator>
  </view>
</view>
