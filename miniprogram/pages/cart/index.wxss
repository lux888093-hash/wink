/* 购物车改版：贴近常见电商购物车结构，但保留项目现有品牌配色 */

.cart-page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-bottom: 228rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.cart-head {
  padding: 8rpx 2rpx 4rpx;
}

.cart-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-head-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.02em;
}

.cart-head-count {
  flex-shrink: 0;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  color: var(--ink-soft);
  font-size: 15rpx;
  line-height: 38rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.cart-board {
  overflow: hidden;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(20, 15, 14, 0.92), rgba(13, 10, 9, 0.94)),
    rgba(13, 10, 9, 0.94);
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  box-shadow: none;
}

.cart-item-outer {
  position: relative;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
}

.cart-image {
  width: 136rpx;
  height: 136rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: rgba(244, 235, 225, 0.08);
}

.cart-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 136rpx;
}

.cart-top-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.cart-remove {
  flex-shrink: 0;
  color: var(--ink-faint);
  font-size: 16rpx;
  line-height: 1.4;
}

.cart-name {
  color: var(--ink);
  flex: 1;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.32;
  letter-spacing: -0.01em;
}

.cart-meta-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 10rpx;
}

.cart-spec-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cart-spec {
  display: inline-flex;
  align-items: center;
  min-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.05);
  color: var(--ink-soft);
  font-size: 14rpx;
}

.cart-note {
  color: var(--ink-faint);
  font-size: 14rpx;
  line-height: 1.45;
}

.cart-bottom-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 12rpx;
}

.cart-price-group {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10rpx;
}

.cart-price {
  color: var(--gold-strong);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.02em;
}

.cart-price-old {
  color: var(--ink-faint);
  font-size: 16rpx;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.05);
}

.qty-btn-plus {
  background: rgba(231, 200, 150, 0.12);
}

.qty-btn-text {
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1;
}

.qty-num {
  min-width: 40rpx;
  text-align: center;
  color: var(--ink);
  font-size: 18rpx;
  font-weight: 600;
  line-height: 44rpx;
}

.cart-item-divider {
  height: 1rpx;
  margin: 0 24rpx;
  background: rgba(226, 199, 159, 0.1);
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 220rpx;
  gap: 14rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.12);
  background: rgba(244, 235, 225, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.empty-icon {
  color: var(--gold-strong);
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.2em;
}

.empty-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.empty-sub {
  color: var(--ink-faint);
  font-size: 18rpx;
  margin-bottom: 20rpx;
}

.empty-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  padding: 0 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  box-shadow: none;
}

.checkout-bar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 104rpx;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    linear-gradient(180deg, rgba(23, 17, 16, 0.96), rgba(13, 10, 9, 0.98)),
    rgba(13, 10, 9, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.14);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.checkout-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-left: auto;
  width: auto;
  max-width: 100%;
}

.checkout-summary {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
  flex-shrink: 1;
  min-width: 0;
}

.checkout-total-label {
  color: var(--ink-soft);
  font-size: 16rpx;
  flex-shrink: 0;
}

.checkout-total-price {
  color: var(--gold-strong);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.02em;
}

.checkout-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 138rpx;
  min-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  box-shadow: none;
}

.tabbar-gap {
  height: 304rpx;
}
