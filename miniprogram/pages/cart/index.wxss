/* 购物车改版：贴近常见电商购物车结构，但保留项目现有品牌配色 */

.cart-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 252rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.cart-head {
  padding: 8rpx 2rpx 4rpx;
}

.cart-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-head-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: 0;
}

.cart-head-count {
  flex-shrink: 0;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.08);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 44rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.cart-board {
  overflow: hidden;
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.14) 0%, rgba(29, 23, 21, 0) 58%),
    linear-gradient(180deg, rgba(44, 38, 32, 0.9), rgba(29, 23, 21, 0.94)),
    var(--panel-strong);
  border: 1rpx solid var(--panel-line);
  box-shadow: none;
}

.cart-item-outer {
  position: relative;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 26rpx;
}

.cart-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: rgba(247, 236, 221, 0.09);
}

.cart-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 144rpx;
}

.cart-top-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.cart-remove {
  flex-shrink: 0;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.4;
}

.cart-name {
  color: var(--ink);
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.32;
  letter-spacing: 0;
}

.cart-meta-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 10rpx;
}

.cart-spec-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cart-spec {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.07);
  color: var(--ink-soft);
  font-size: 20rpx;
}

.cart-note {
  color: var(--ink-faint);
  font-size: 20rpx;
  line-height: 1.45;
}

.cart-bottom-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 12rpx;
}

.cart-price-group {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10rpx;
}

.cart-price {
  color: var(--gold-strong);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0;
}

.cart-price-old {
  color: var(--ink-faint);
  font-size: 20rpx;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.07);
}

.qty-btn-plus {
  background: rgba(239, 208, 155, 0.14);
}

.qty-btn-text {
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1;
}

.qty-num {
  min-width: 46rpx;
  text-align: center;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.cart-item-divider {
  height: 1rpx;
  margin: 0 24rpx;
  background: rgba(220, 185, 133, 0.12);
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 220rpx;
  gap: 14rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--panel-line);
  background: rgba(247, 236, 221, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.empty-icon {
  color: var(--gold-strong);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.empty-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.empty-sub {
  color: var(--ink-faint);
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.empty-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ead0a3 0%, #b8874c 78%, #8d5b34 100%);
  color: #241b14;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  box-shadow: none;
}

.checkout-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 116rpx;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(135deg, rgba(93, 31, 37, 0.18), rgba(24, 18, 17, 0) 58%),
    linear-gradient(180deg, rgba(38, 32, 27, 0.96), rgba(18, 14, 13, 0.98)),
    rgba(18, 14, 13, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(18, 15, 12, 0.14);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.checkout-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-left: auto;
  width: auto;
  max-width: 100%;
}

.checkout-summary {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
  flex-shrink: 1;
  min-width: 0;
}

.checkout-total-label {
  color: var(--ink-soft);
  font-size: 20rpx;
  flex-shrink: 0;
}

.checkout-total-price {
  color: var(--gold-strong);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0;
}

.checkout-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 150rpx;
  min-height: 78rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ead0a3 0%, #b8874c 78%, #8d5b34 100%);
  color: #241b14;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  box-shadow: none;
}

.tabbar-gap {
  height: 328rpx;
}
