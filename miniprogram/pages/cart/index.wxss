/* 购物车改版：贴近常见电商购物车结构，但保留项目现有品牌配色 */

.cart-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 220rpx;
}

.cart-head {
  padding: 4rpx 4rpx 6rpx;
}

.cart-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-head-title {
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.1;
}

.cart-head-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  color: var(--ink-soft);
  font-size: 18rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.cart-board {
  overflow: hidden;
}

.cart-item-outer {
  position: relative;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
}

.cart-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: rgba(244, 235, 225, 0.08);
}

.cart-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 148rpx;
}

.cart-top-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.cart-remove {
  flex-shrink: 0;
  color: var(--ink-faint);
  font-size: 18rpx;
  line-height: 1.4;
}

.cart-name {
  color: var(--ink);
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.cart-meta-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 12rpx;
}

.cart-spec-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cart-spec {
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(244, 235, 225, 0.08);
  color: var(--ink-soft);
  font-size: 16rpx;
}

.cart-note {
  color: var(--ink-faint);
  font-size: 16rpx;
  line-height: 1.45;
}

.cart-bottom-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.cart-price-group {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10rpx;
}

.cart-price {
  color: var(--gold-strong);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.cart-price-old {
  color: var(--ink-faint);
  font-size: 18rpx;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(244, 235, 225, 0.06);
}

.qty-btn-plus {
  background: rgba(231, 200, 150, 0.16);
}

.qty-btn-text {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1;
}

.qty-num {
  min-width: 48rpx;
  text-align: center;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.cart-item-divider {
  height: 1rpx;
  margin: 0 24rpx;
  background: rgba(226, 199, 159, 0.1);
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
  gap: 16rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(244, 235, 225, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 36rpx;
  font-weight: 600;
}

.empty-sub {
  color: var(--ink-faint);
  font-size: 22rpx;
  margin-bottom: 24rpx;
}

.empty-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 0 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  box-shadow: 0 18rpx 34rpx rgba(135, 91, 50, 0.22);
}

.checkout-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 118rpx;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 20rpx 16rpx 20rpx;
  border-top: 1rpx solid rgba(226, 199, 159, 0.12);
  background:
    linear-gradient(180deg, rgba(23, 17, 16, 0.96), rgba(13, 10, 9, 0.98)),
    rgba(13, 10, 9, 0.96);
  box-shadow: 0 -8rpx 26rpx rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.checkout-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.checkout-summary {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 10rpx;
}

.checkout-total-label {
  color: var(--ink-soft);
  font-size: 18rpx;
  flex-shrink: 0;
}

.checkout-total-price {
  color: var(--gold-strong);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.checkout-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 150rpx;
  min-height: 78rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  box-shadow: 0 16rpx 32rpx rgba(135, 91, 50, 0.2);
}

.tabbar-gap {
  height: 320rpx;
}
