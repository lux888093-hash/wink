/* ===== 购物袋页面 — Apple / 山姆风格 ===== */

.cart-page {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* --- 头部 --- */
.cart-head {
  padding: 16rpx 4rpx 28rpx;
}

.cart-head-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.cart-head-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 52rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1.1;
}

.cart-head-count {
  color: var(--ink-faint);
  font-size: 22rpx;
  letter-spacing: 0.06em;
}

/* --- 商品列表 --- */
.cart-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* --- 滑动删除容器 --- */
.cart-item-outer {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.swipe-wrapper {
  position: relative;
}

.swipe-content {
  position: relative;
  z-index: 2;
  transition: transform 0.28s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c0392b, #96281b);
  border-radius: 0 28rpx 28rpx 0;
  z-index: 1;
}

.swipe-delete-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.12em;
}

/* --- 商品卡片 --- */
.cart-item {
  display: flex;
  gap: 24rpx;
  padding: 20rpx;
  align-items: flex-start;
}

.cart-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: var(--bg-strong);
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200rpx;
  padding: 4rpx 0;
}

.cart-name {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: 0.01em;
}

.cart-spec-row {
  margin-top: 8rpx;
}

.cart-spec {
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  color: var(--ink-faint);
  font-size: 18rpx;
  letter-spacing: 0.04em;
}

.cart-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 14rpx;
}

/* --- 价格 --- */
.cart-price-group {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.cart-price {
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 28rpx;
  font-weight: 600;
  font-variant-numeric: lining-nums;
}

.cart-price-old {
  color: var(--ink-faint);
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
  font-variant-numeric: lining-nums;
}

/* --- 数量步进器 (Apple 风格胶囊) --- */
.qty-stepper {
  display: flex;
  align-items: center;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  border: 1rpx solid rgba(244, 235, 225, 0.08);
  overflow: hidden;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
}

.qty-btn-text {
  color: var(--ink-soft);
  font-size: 28rpx;
  font-weight: 300;
  line-height: 1;
}

.qty-num {
  min-width: 40rpx;
  text-align: center;
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* --- 空状态 --- */
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
  gap: 16rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(244, 235, 225, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 36rpx;
  font-weight: 600;
}

.empty-sub {
  color: var(--ink-faint);
  font-size: 22rpx;
  margin-bottom: 24rpx;
}

.empty-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 0 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  box-shadow: 0 18rpx 34rpx rgba(135, 91, 50, 0.22);
}

/* --- 底部结算栏 (浮在 tabbar dock 上方) --- */
.checkout-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 110rpx;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(26, 20, 18, 0.94), rgba(11, 8, 8, 0.96)),
    rgba(15, 11, 10, 0.92);
  border: 1rpx solid rgba(226, 199, 159, 0.12);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.32);
}

.checkout-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.checkout-total-label {
  color: var(--ink-faint);
  font-size: 18rpx;
  letter-spacing: 0.08em;
}

.checkout-total-price {
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  font-weight: 600;
  font-variant-numeric: lining-nums;
}

.checkout-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2e0c3 0%, #d5a15a 48%, #704221 100%);
  color: #26150d;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  box-shadow: 0 14rpx 28rpx rgba(135, 91, 50, 0.22);
}

/* --- tabbar gap: 结算栏 + dock 高度 --- */
.tabbar-gap {
  height: 280rpx;
}
