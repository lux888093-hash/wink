<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll cellar-page">
    <view class="cellar-hero">
      <image class="cellar-hero-image" src="{{wine.estateHeroImage}}" mode="aspectFill"></image>
      <view class="cellar-hero-mask"></view>
      <view class="cellar-hero-copy">
        <text class="cellar-kicker">ESTATE</text>
        <text class="cellar-title">{{wine.estateName}}</text>
        <text class="cellar-tagline">{{wine.estateTagline}}</text>
      </view>
    </view>

    <view class="cellar-facts">
      <view class="cellar-fact" wx:for="{{wine.estateStats}}" wx:key="label">
        <text class="cellar-fact-label">{{item.label}}</text>
        <text class="cellar-fact-value">{{item.value}}</text>
      </view>
    </view>

    <view class="cellar-statement">
      <view class="cellar-statement-copy">
        <view class="cellar-statement-head">
          <text class="cellar-statement-kicker">酒庄档案</text>
          <text class="cellar-statement-sub">Estate file</text>
        </view>
        <text class="cellar-statement-title">风土与夜色的秩序</text>
        <view class="cellar-statement-rule"></view>
        <text class="cellar-statement-body">{{wine.estatePhilosophy}}</text>
      </view>
    </view>

    <view class="cellar-scenes">
      <view class="cellar-scene" wx:for="{{collection}}" wx:key="id" bindtap="openDetail" hover-class="cellar-scene-press" hover-stay-time="80">
        <image class="cellar-scene-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="cellar-scene-mask"></view>
        <view class="cellar-scene-copy">
          <text class="cellar-scene-eyebrow">{{item.vintage}}</text>
          <text class="cellar-scene-title">{{item.title}}</text>
          <text class="cellar-scene-note line-clamp-2">{{item.note}}</text>
        </view>
      </view>
    </view>

    <view class="tabbar-gap"></view>
    <editorial-tabbar active="cellar"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <button class="ghost-button" bindtap="goBack">返回输入提取码</button>
  </view>
</view>
