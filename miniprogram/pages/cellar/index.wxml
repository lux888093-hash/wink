<view class="shell">
  <view wx:if="{{ready}}" class="page-scroll cellar-page">
    <view class="section-panel cellar-hero">
      <image class="cellar-hero-image" src="{{wine.estateHeroImage}}" mode="aspectFill"></image>
      <view class="cellar-hero-mask"></view>
      <view class="cellar-hero-copy">
        <text class="eyebrow">扫码专属</text>
        <text class="display-title cellar-title">{{wine.name}}</text>
        <text class="muted-copy line-clamp-3">{{wine.estateIntro}}</text>
      </view>
      <view class="cellar-hero-note">
        <text class="micro-copy line-clamp-2">{{wine.quote}}</text>
      </view>
    </view>

    <view class="paper-panel dossier-card">
      <text class="eyebrow dossier-kicker">{{wine.estateName}}</text>
      <text class="section-title">{{wine.estateTagline}}</text>
      <text class="muted-copy">{{wine.estatePhilosophy}}</text>

      <view class="dossier-list">
        <view class="dossier-item" wx:for="{{wine.estateStats}}" wx:key="label">
          <text class="dossier-label">{{item.label}}</text>
          <text class="dossier-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view>
        <text class="eyebrow">庄园印象</text>
        <text class="section-title">庄园画面</text>
      </view>
    </view>

    <view class="memory-list">
      <view class="section-panel memory-card" wx:for="{{collection}}" wx:key="id">
        <image class="memory-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="memory-copy">
          <text class="memory-meta">{{item.vintage}}</text>
          <text class="memory-title">{{item.title}}</text>
          <text class="micro-copy line-clamp-2">{{item.note}}</text>
        </view>
      </view>
    </view>

    <view class="action-row">
      <button class="ghost-button action-button" bindtap="openDetail">看酒款</button>
      <button class="primary-button action-button" bindtap="openMelody">听配乐</button>
    </view>

    <view class="tabbar-gap"></view>
    <editorial-tabbar active="cellar"></editorial-tabbar>
  </view>

  <view wx:else class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator class="ghost-button" url="/pages/redeem/index">返回扫码页</navigator>
  </view>
</view>
