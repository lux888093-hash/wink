.cellar-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-top: 0;
}

.cellar-hero {
  min-height: 760rpx;
  margin: -30rpx -24rpx 0;
  border-radius: 0 0 16rpx 16rpx;
  border: 0;
  box-shadow: none;
}

.cellar-hero-image,
.cellar-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cellar-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.26) 0%, rgba(24, 21, 18, 0) 52%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.06) 0%, rgba(18, 14, 13, 0.24) 38%, rgba(18, 14, 13, 0.88) 100%),
    linear-gradient(90deg, rgba(18, 14, 13, 0.62), rgba(18, 14, 13, 0.1) 54%, rgba(18, 14, 13, 0.42));
}

.cellar-hero-copy {
  position: relative;
  z-index: 2;
  padding: 92rpx 30rpx 228rpx;
}

.cellar-title {
  max-width: 620rpx;
  margin: 12rpx 0 14rpx;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 52rpx;
  font-weight: 600;
  line-height: 1.06;
}

.cellar-hero-note {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 34rpx;
  z-index: 2;
  padding: 0;
  border-radius: 0;
  background:
    linear-gradient(90deg, rgba(220, 192, 138, 0.32), rgba(220, 192, 138, 0));
  border-top: 1rpx solid rgba(220, 192, 138, 0.24);
}

.cellar-hero-note .micro-copy {
  padding-top: 18rpx;
  color: rgba(247, 239, 228, 0.78);
}

.dossier-card {
  margin: 0 -24rpx;
  padding: 54rpx 30rpx 50rpx;
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.cellar-page .section-head {
  padding: 46rpx 4rpx 0;
}

.dossier-kicker {
  color: rgba(63, 42, 20, 0.68);
}

.dossier-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 30rpx;
}

.dossier-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(63, 42, 20, 0.1);
}

.dossier-label {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(63, 42, 20, 0.56);
  font-size: 20rpx;
}

.dossier-value {
  display: block;
  color: var(--paper-ink);
  font-size: 22rpx;
  line-height: 1.58;
}

.memory-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 22rpx -24rpx 0;
}

.memory-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border: 0;
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
  border-radius: 0;
  box-shadow: none;
}

.memory-image {
  width: 204rpx;
  height: 184rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.memory-copy {
  flex: 1;
}

.memory-meta {
  display: block;
  margin-bottom: 8rpx;
  color: var(--gold);
  font-size: 20rpx;
  letter-spacing: 0;
}

.memory-title {
  display: block;
  margin-bottom: 8rpx;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.22;
}
