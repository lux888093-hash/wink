.cellar-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.cellar-hero {
  min-height: 520rpx;
  border-radius: 36rpx;
}

.cellar-hero-image,
.cellar-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cellar-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.18) 0%, rgba(24, 21, 18, 0) 50%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.12) 0%, rgba(18, 14, 13, 0.78) 100%);
}

.cellar-hero-copy {
  position: relative;
  z-index: 2;
  padding: 34rpx 28rpx 162rpx;
}

.cellar-title {
  margin: 10rpx 0 12rpx;
}

.cellar-hero-note {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  padding: 20rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(93, 31, 37, 0.2), rgba(24, 21, 18, 0) 58%),
    linear-gradient(180deg, rgba(44, 38, 32, 0.58), rgba(18, 14, 13, 0.5));
}

.dossier-card {
  padding: 24rpx;
}

.dossier-kicker {
  color: rgba(63, 42, 20, 0.68);
}

.dossier-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.dossier-item {
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(63, 42, 20, 0.08);
}

.dossier-label {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(63, 42, 20, 0.56);
  font-size: 20rpx;
}

.dossier-value {
  display: block;
  color: var(--paper-ink);
  font-size: 22rpx;
  line-height: 1.58;
}

.memory-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.memory-card {
  display: flex;
  gap: 14rpx;
  padding: 16rpx;
}

.memory-image {
  width: 176rpx;
  height: 156rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.memory-copy {
  flex: 1;
}

.memory-meta {
  display: block;
  margin-bottom: 8rpx;
  color: var(--gold);
  font-size: 20rpx;
  letter-spacing: 0;
}

.memory-title {
  display: block;
  margin-bottom: 8rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 27rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.action-button {
  flex: 1;
}
