.cellar-page {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 24rpx 212rpx;
  background:
    linear-gradient(180deg, rgba(37, 21, 21, 0.92) 0%, rgba(23, 18, 17, 1) 32%, rgba(18, 16, 15, 1) 100%),
    var(--bg);
}

.cellar-hero {
  position: relative;
  min-height: 920rpx;
  margin: 0 -24rpx;
  overflow: hidden;
  background: var(--bg);
}

.cellar-hero-image,
.cellar-hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cellar-hero-mask {
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.16) 0%, rgba(24, 21, 18, 0) 48%),
    linear-gradient(180deg, rgba(16, 13, 12, 0.04) 0%, rgba(42, 16, 19, 0.18) 46%, rgba(18, 14, 13, 0.94) 100%),
    linear-gradient(90deg, rgba(18, 14, 13, 0.62) 0%, rgba(24, 21, 18, 0.08) 52%, rgba(18, 14, 13, 0.24) 100%);
}

.cellar-hero-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 146rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 540rpx;
}

.cellar-kicker,
.cellar-scene-eyebrow,
.cellar-fact-label,
.cellar-statement-kicker {
  display: block;
  color: rgba(231, 200, 150, 0.78);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.cellar-title {
  display: block;
  max-width: 560rpx;
  margin: 16rpx 0 12rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 62rpx;
  font-weight: 600;
  line-height: 1.04;
  letter-spacing: 0;
}

.cellar-tagline {
  display: block;
  max-width: 460rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.34;
  letter-spacing: 0;
}

.cellar-facts {
  display: flex;
  gap: 0;
  position: relative;
  z-index: 3;
  margin: -112rpx -24rpx 0;
  padding: 26rpx 24rpx 50rpx;
  border-top: 1rpx solid rgba(220, 185, 133, 0.18);
  background:
    linear-gradient(180deg, rgba(23, 18, 17, 0.14), rgba(23, 18, 17, 0.96) 46%, rgba(23, 18, 17, 1) 100%);
  backdrop-filter: blur(18rpx);
}

.cellar-fact {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  border-left: 1rpx solid rgba(231, 200, 150, 0.14);
}

.cellar-fact:first-child {
  border-left: 0;
  padding-left: 0;
}

.cellar-fact:last-child {
  padding-right: 0;
}

.cellar-fact-value {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.36;
  letter-spacing: 0;
}

.cellar-statement {
  position: relative;
  margin: 0 -24rpx;
  min-height: 300rpx;
  padding: 52rpx 30rpx 58rpx;
  display: flex;
  align-items: flex-start;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(220, 185, 133, 0.12), rgba(220, 185, 133, 0) 42%),
    linear-gradient(135deg, rgba(93, 31, 37, 0.24), rgba(93, 31, 37, 0) 58%),
    linear-gradient(180deg, rgba(31, 24, 21, 0.98), rgba(18, 14, 13, 1));
  border-top: 1rpx solid rgba(220, 185, 133, 0.1);
  border-bottom: 1rpx solid rgba(220, 185, 133, 0.08);
}

.cellar-statement-copy {
  position: relative;
  flex: 1;
  min-width: 0;
}

.cellar-statement-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.cellar-statement-sub {
  color: rgba(255, 246, 235, 0.38);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: 0;
}

.cellar-statement-title {
  display: block;
  max-width: 570rpx;
  color: rgba(255, 250, 242, 0.96);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.16;
  letter-spacing: 0;
}

.cellar-statement-rule {
  width: 116rpx;
  height: 1rpx;
  margin: 24rpx 0 22rpx;
  background: linear-gradient(90deg, rgba(220, 192, 138, 0.76), rgba(220, 192, 138, 0));
}

.cellar-statement-body {
  display: block;
  max-width: 570rpx;
  color: rgba(255, 246, 235, 0.72);
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.68;
  letter-spacing: 0;
}

.cellar-scenes {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0 -24rpx;
  padding: 0;
  background: var(--bg);
}

.cellar-scene {
  position: relative;
  min-height: 560rpx;
  overflow: hidden;
  background: var(--bg-strong);
  transition: opacity 0.18s ease;
}

.cellar-scene:first-child {
  min-height: 680rpx;
}

.cellar-scene-image,
.cellar-scene-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cellar-scene-mask {
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.12) 0%, rgba(24, 21, 18, 0) 52%),
    linear-gradient(180deg, rgba(31, 27, 23, 0.02) 0%, rgba(42, 16, 19, 0.1) 42%, rgba(18, 14, 13, 0.86) 100%),
    linear-gradient(90deg, rgba(24, 18, 17, 0.52), rgba(24, 21, 18, 0.02) 62%, rgba(24, 18, 17, 0.22));
}

.cellar-scene-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 34rpx;
  z-index: 2;
}

.cellar-scene-title {
  display: block;
  max-width: 560rpx;
  margin-top: 12rpx;
  color: #ffffff;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: 0;
}

.cellar-scene-note {
  display: block;
  max-width: 560rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 23rpx;
  line-height: 1.5;
  letter-spacing: 0;
}

.cellar-scene-press {
  opacity: 0.9;
}
