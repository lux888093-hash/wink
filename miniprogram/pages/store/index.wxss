.store-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  max-width: 100%;
  overflow-x: hidden;
}

.store-head {
  padding: 8rpx 2rpx 4rpx;
}

.store-title {
  margin: 10rpx 0 12rpx;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  gap: 10rpx;
  padding: 0 24rpx 0 0;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.14);
  background: rgba(244, 235, 225, 0.04);
  color: var(--ink-soft);
  font-size: 17rpx;
  line-height: 1;
}

.category-chip.is-active {
  background:
    linear-gradient(180deg, rgba(214, 177, 124, 0.14), rgba(214, 177, 124, 0.08)),
    rgba(214, 177, 124, 0.12);
  color: #f0d4ac;
}

.catalog-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.catalog-card {
  padding: 14rpx;
}

.catalog-image {
  width: 100%;
  height: 324rpx;
  border-radius: 24rpx;
}

.catalog-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 8rpx 8rpx;
}

.catalog-title {
  margin-top: 2rpx;
}

.catalog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.catalog-tag {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  color: var(--ink-faint);
  font-size: 15rpx;
}

.catalog-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.catalog-cta {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.14);
  color: var(--gold);
  font-size: 16rpx;
  letter-spacing: 0.14em;
}
