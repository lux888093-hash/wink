.store-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  max-width: 100%;
  overflow-x: hidden;
}

.store-head {
  padding: 6rpx 2rpx 0;
}

.store-title {
  margin: 4rpx 0 0;
}

.featured-card {
  position: relative;
  min-height: 420rpx;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.12);
  background: rgba(17, 13, 12, 0.94);
}

.featured-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.featured-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background:
    linear-gradient(180deg, rgba(8, 6, 6, 0.08) 0%, rgba(8, 6, 6, 0.28) 38%, rgba(8, 6, 6, 0.84) 100%),
    linear-gradient(90deg, rgba(8, 6, 6, 0.72), rgba(8, 6, 6, 0.06));
}

.featured-copy {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.featured-kicker {
  display: block;
  color: var(--gold-strong);
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 0;
}

.featured-title {
  display: block;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 34rpx;
  line-height: 1.12;
  letter-spacing: 0;
}

.featured-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.featured-price {
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  line-height: 1;
  font-variant-numeric: lining-nums;
}

.featured-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(231, 200, 150, 0.22);
  background: rgba(244, 235, 225, 0.08);
  color: var(--gold-strong);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0;
}

.catalog-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx 18rpx;
}

.catalog-card {
  position: relative;
  width: calc((100% - 18rpx) / 2);
  min-height: 414rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 10rpx;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.12);
  background: rgba(17, 13, 12, 0.94);
}

.catalog-image {
  width: 100%;
  height: 238rpx;
  border-radius: 14rpx;
  background: rgba(244, 235, 225, 0.04);
}

.catalog-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 144rpx;
  padding: 0 4rpx 4rpx;
}

.catalog-meta {
  display: block;
  color: var(--gold);
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 0;
}

.catalog-title {
  display: block;
  min-height: 58rpx;
  color: var(--ink);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 26rpx;
  line-height: 1.16;
  letter-spacing: 0;
}

.catalog-footer {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-top: auto;
  padding-right: 70rpx;
}

.catalog-price {
  color: var(--gold-strong);
  font-family: Baskerville, Georgia, "Times New Roman", serif;
  font-size: 30rpx;
  line-height: 1;
  font-variant-numeric: lining-nums;
}

.catalog-cart-button {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 76rpx;
  height: 76rpx;
  padding: 0;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  background: transparent;
  box-shadow: none;
  z-index: 2;
}

.catalog-cart-button.is-loading {
  opacity: 0.62;
}

.catalog-cart-button.is-disabled {
  opacity: 0.4;
}

.catalog-cart-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5e7cd 0%, #d49b54 100%);
  box-shadow:
    0 8rpx 18rpx rgba(0, 0, 0, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.46);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.catalog-cart-button:active .catalog-cart-icon {
  transform: scale(0.9);
  opacity: 0.86;
}

.cart-icon-svg {
  width: 30rpx;
  height: 30rpx;
  filter: brightness(0) saturate(100%);
}

.catalog-cart-button.is-disabled .catalog-cart-icon {
  background: rgba(244, 235, 225, 0.08);
  box-shadow: none;
}


.catalog-empty {
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.catalog-empty-text {
  color: var(--ink-faint);
  font-size: 23rpx;
  line-height: 1.4;
  letter-spacing: 0;
}
