<view class="shell">
  <view wx:if="{{pageReady}}" class="page-scroll store-page">
    <view class="store-head">
      <text class="eyebrow">CURATED CELLAR</text>
      <text class="display-title store-title">酒廊</text>
    </view>

    <view
      wx:if="{{featuredItem}}"
      class="featured-card"
      data-product-id="{{featuredItem.id}}"
      bindtap="openProduct"
    >
      <image class="featured-image" src="{{featuredItem.coverImage}}" mode="aspectFill"></image>
      <view class="featured-shade"></view>
      <view class="featured-copy">
        <text class="featured-kicker">{{featuredItem.badge}}</text>
        <text class="featured-title line-clamp-1">{{featuredItem.name}}</text>
        <view class="featured-footer">
          <text class="featured-price">¥{{featuredItem.lowestPrice}}</text>
          <text class="featured-link">查看</text>
        </view>
      </view>
    </view>

    <view wx:if="{{gridItems.length}}" class="catalog-grid">
      <view
        class="catalog-card"
        wx:for="{{gridItems}}"
        wx:key="id"
        data-product-id="{{item.id}}"
        bindtap="openProduct"
      >
        <image class="catalog-image" src="{{item.coverImage}}" mode="aspectFill"></image>
        <view class="catalog-copy">
          <text class="catalog-meta">{{item.category}}</text>
          <text class="catalog-title line-clamp-2">{{item.name}}</text>
          <view class="catalog-footer">
            <text class="catalog-price">¥{{item.lowestPrice}}</text>
            <button
              class="catalog-cart-button {{item.canQuickAdd ? '' : 'is-disabled'}} {{addingSkuId && addingSkuId === item.firstSkuId ? 'is-loading' : ''}}"
              data-sku-id="{{item.canQuickAdd ? item.firstSkuId : ''}}"
              catchtap="addToCart"
            >
              <view class="catalog-cart-icon">
                <image class="cart-icon-svg" src="/assets/icons/cart-light.svg"></image>
              </view>
            </button>
          </view>
        </view>
      </view>
    </view>
    <view wx:elif="{{!featuredItem}}" class="catalog-empty">
      <text class="catalog-empty-text">暂无商品</text>
    </view>

    <view class="tabbar-gap"></view>
    <boutique-tabbar active="store" cartCount="{{cartCount}}"></boutique-tabbar>
  </view>

  <view wx:elif="{{errorTitle}}" class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <button class="ghost-button" bindtap="loadPage">重新加载</button>
  </view>
</view>
