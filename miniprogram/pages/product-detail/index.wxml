<view class="shell">
  <view wx:if="{{pageReady}}" class="page-scroll product-page">
    <view class="hero-gallery section-panel">
      <image class="hero-gallery-main" src="{{product.coverImage}}" mode="aspectFill"></image>
      <view class="hero-gallery-mask"></view>
      <view class="hero-gallery-copy">
        <view class="chip-row">
          <text class="chip">{{product.badge}}</text>
          <text class="chip">{{product.category}}</text>
        </view>
        <text class="display-title product-title">{{product.name}}</text>
        <text class="micro-copy hero-gallery-subtitle line-clamp-2">{{product.subtitle}}</text>
        <view class="price-row product-price">
          <text class="price-current">¥{{selectedSku.price}}</text>
          <text class="price-original">¥{{selectedSku.marketPrice}}</text>
        </view>
      </view>
    </view>

    <view class="hero-gallery-strip">
      <image
        wx:for="{{product.gallery}}"
        wx:key="*this"
        class="hero-gallery-thumb"
        src="{{item}}"
        mode="aspectFill"
      ></image>
    </view>

    <view class="paper-panel product-paper">
      <text class="eyebrow">礼盒概述</text>
      <text class="muted-copy line-clamp-3">{{product.story}}</text>

      <view class="sku-list">
        <button
          wx:for="{{product.skus}}"
          wx:key="id"
          class="sku-chip {{selectedSkuId === item.id ? 'is-active' : ''}}"
          data-sku-id="{{item.id}}"
          bindtap="selectSku"
        >
          <text class="sku-name">{{item.specName}}</text>
          <text class="sku-meta">库存 {{item.stock}}</text>
        </button>
      </view>
    </view>

    <view class="section-panel detail-panel">
      <text class="eyebrow">酒款信息</text>
      <text class="section-title">{{product.wine.name}}</text>
      <text class="micro-copy line-clamp-3">{{product.wine.overview}}</text>

      <view class="detail-grid">
        <view class="detail-grid-item">
          <text class="detail-label">产区</text>
          <text class="detail-value">{{product.wine.region}}</text>
        </view>
        <view class="detail-grid-item">
          <text class="detail-label">葡萄品种</text>
          <text class="detail-value">{{product.wine.grapes}}</text>
        </view>
        <view class="detail-grid-item">
          <text class="detail-label">酒精度</text>
          <text class="detail-value">{{product.wine.abv}}</text>
        </view>
        <view class="detail-grid-item">
          <text class="detail-label">建议饮用</text>
          <text class="detail-value">{{product.wine.serving}}</text>
        </view>
      </view>
    </view>

    <view class="section-panel highlight-panel">
      <text class="eyebrow">礼盒亮点</text>
      <view class="highlight-grid">
        <view class="highlight-card" wx:for="{{product.highlights}}" wx:key="*this" wx:for-index="index">
          <text class="highlight-index">0{{index + 1}}</text>
          <text class="micro-copy line-clamp-2">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="sticky-action section-panel">
      <button class="ghost-button sticky-button" bindtap="addToCart">加入购物袋</button>
      <button class="primary-button sticky-button" bindtap="buyNow">立即结算</button>
    </view>
  </view>

  <view wx:elif="{{errorTitle}}" class="page-scroll empty-state">
    <text class="empty-title">{{errorTitle}}</text>
    <text class="empty-subtitle">{{errorMessage}}</text>
    <navigator class="ghost-button" url="/pages/store/index">返回酒廊</navigator>
  </view>
</view>
