.product-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 244rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.product-gallery {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.2) 0%, rgba(29, 23, 21, 0) 52%),
    linear-gradient(180deg, rgba(48, 39, 33, 0.98), rgba(24, 18, 17, 0.98)),
    var(--panel-strong);
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.product-swiper {
  height: 548rpx;
}

.product-swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 548rpx;
  padding: 70rpx 40rpx 78rpx;
}

.product-swiper-image {
  width: 100%;
  height: 100%;
}

.product-gallery-head {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.product-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.product-chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.08);
  color: var(--ink);
  font-size: 20rpx;
  line-height: 1;
}

.product-chip-muted {
  color: var(--ink-soft);
  background: rgba(247, 236, 221, 0.06);
}

.product-gallery-index {
  flex-shrink: 0;
  min-width: 98rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(24, 21, 18, 0.46);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 44rpx;
  text-align: center;
}

.product-gallery-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 22rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.product-gallery-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(246, 239, 231, 0.24);
}

.product-gallery-dot.is-active {
  width: 28rpx;
  background: var(--gold-strong);
}

.product-summary,
.product-content {
  position: relative;
  overflow: hidden;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(93, 31, 37, 0.14) 0%, rgba(29, 23, 21, 0) 58%),
    linear-gradient(180deg, rgba(44, 38, 32, 0.88), rgba(29, 23, 21, 0.94)),
    var(--panel-strong);
}

.product-summary {
  padding-top: 32rpx;
}

.product-content {
  padding-top: 28rpx;
}

.product-name {
  display: block;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: 0;
}

.product-subtitle {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.45;
}

.product-wine-line {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-faint);
  font-size: 22rpx;
  line-height: 1.45;
}

.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.product-price-stack {
  min-width: 0;
}

.product-price-label {
  display: block;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1;
}

.product-price-main {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.product-price-value {
  color: var(--gold-strong);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0;
}

.product-price-market {
  color: var(--ink-faint);
  font-size: 21rpx;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.product-stock {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(143, 167, 119, 0.14);
  color: #c5d8a7;
  flex-shrink: 0;
}

.product-stock.is-out {
  background: rgba(220, 38, 38, 0.12);
  color: #f0aaa1;
}

.product-stock-text {
  font-size: 21rpx;
  line-height: 1;
}

.product-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.product-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 221, 0.07);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1;
}

.summary-divider,
.content-divider {
  height: 1rpx;
  margin: 26rpx 0 22rpx;
  background: rgba(220, 185, 133, 0.13);
}

.sku-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sku-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.sku-title {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1;
}

.sku-selected {
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.4;
  text-align: right;
  min-width: 0;
}

.sku-row {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  width: 100%;
}

.sku-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex: 1 1 0;
  min-width: 0;
  min-height: 90rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(220, 185, 133, 0.13);
  background: rgba(247, 236, 221, 0.055);
  color: var(--ink);
  transition: background 180ms ease, border-color 180ms ease, opacity 180ms ease;
}

.sku-option.is-active {
  border-color: rgba(239, 208, 155, 0.28);
  background: rgba(239, 208, 155, 0.1);
  box-shadow: none;
}

.sku-option-hover {
  opacity: 0.88;
}

.sku-option-name {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sku-option-price {
  flex-shrink: 0;
  color: var(--gold-strong);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.content-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.content-copy {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.58;
}

.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.highlight-bullet {
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: var(--gold);
  flex-shrink: 0;
}

.highlight-text {
  flex: 1;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.meta-list {
  display: flex;
  flex-direction: column;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(220, 185, 133, 0.1);
}

.meta-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.meta-label {
  flex-shrink: 0;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.5;
}

.meta-value {
  text-align: right;
  color: var(--ink);
  font-size: 21rpx;
  line-height: 1.54;
}

.sticky-action {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  z-index: 24;
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--panel-line);
  background:
    linear-gradient(135deg, rgba(93, 31, 37, 0.18), rgba(24, 18, 17, 0) 58%),
    linear-gradient(180deg, rgba(38, 32, 27, 0.98), rgba(18, 14, 13, 0.98)),
    rgba(18, 14, 13, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(18, 15, 12, 0.14);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.sticky-button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.sticky-button-secondary {
  border: 1rpx solid rgba(220, 185, 133, 0.22);
  background: rgba(247, 236, 221, 0.06);
  color: var(--ink);
}

.sticky-button-secondary-hover {
  background: rgba(247, 236, 221, 0.1);
}

.sticky-button-primary {
  box-shadow: none;
}

.sticky-button-primary-hover {
  opacity: 0.9;
}

.sticky-button[disabled] {
  opacity: 0.4;
  box-shadow: none;
}
