.product-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 244rpx;
  font-family: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.product-gallery {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    radial-gradient(circle at 50% 18%, rgba(231, 200, 150, 0.12), rgba(231, 200, 150, 0)),
    linear-gradient(180deg, rgba(22, 17, 16, 0.98), rgba(12, 10, 9, 0.98));
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.product-swiper {
  height: 548rpx;
}

.product-swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 548rpx;
  padding: 70rpx 40rpx 78rpx;
}

.product-swiper-image {
  width: 100%;
  height: 100%;
}

.product-gallery-head {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.product-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.product-chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.06);
  color: var(--ink);
  font-size: 20rpx;
  line-height: 1;
}

.product-chip-muted {
  color: var(--ink-soft);
  background: rgba(244, 235, 225, 0.05);
}

.product-gallery-index {
  flex-shrink: 0;
  min-width: 98rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(8, 6, 5, 0.38);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 44rpx;
  text-align: center;
}

.product-gallery-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 22rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.product-gallery-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(246, 239, 231, 0.24);
}

.product-gallery-dot.is-active {
  width: 28rpx;
  background: var(--gold-strong);
}

.product-summary,
.product-content {
  position: relative;
  overflow: hidden;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(20, 15, 14, 0.9), rgba(13, 10, 9, 0.92)),
    rgba(13, 10, 9, 0.92);
}

.product-summary {
  padding-top: 32rpx;
}

.product-content {
  padding-top: 28rpx;
}

.product-name {
  display: block;
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: 0;
}

.product-subtitle {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.45;
}

.product-wine-line {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-faint);
  font-size: 22rpx;
  line-height: 1.45;
}

.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.product-price-stack {
  min-width: 0;
}

.product-price-label {
  display: block;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1;
}

.product-price-main {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.product-price-value {
  color: var(--gold-strong);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0;
}

.product-price-market {
  color: var(--ink-faint);
  font-size: 21rpx;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.product-stock {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(142, 164, 113, 0.12);
  color: #b8d093;
  flex-shrink: 0;
}

.product-stock.is-out {
  background: rgba(220, 38, 38, 0.12);
  color: #ef8c8c;
}

.product-stock-text {
  font-size: 21rpx;
  line-height: 1;
}

.product-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.product-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 225, 0.05);
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1;
}

.summary-divider,
.content-divider {
  height: 1rpx;
  margin: 26rpx 0 22rpx;
  background: rgba(226, 199, 159, 0.1);
}

.sku-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sku-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.sku-title {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1;
}

.sku-selected {
  color: var(--ink-soft);
  font-size: 20rpx;
  line-height: 1.4;
  text-align: right;
  min-width: 0;
}

.sku-row {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  width: 100%;
}

.sku-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex: 1 1 0;
  min-width: 0;
  min-height: 90rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.1);
  background: rgba(244, 235, 225, 0.035);
  color: var(--ink);
  transition: background 180ms ease, border-color 180ms ease, opacity 180ms ease;
}

.sku-option.is-active {
  border-color: rgba(231, 200, 150, 0.2);
  background: rgba(231, 200, 150, 0.08);
  box-shadow: none;
}

.sku-option-hover {
  opacity: 0.88;
}

.sku-option-name {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sku-option-price {
  flex-shrink: 0;
  color: var(--gold-strong);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.content-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-title {
  color: var(--ink);
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0;
}

.content-copy {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.58;
}

.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.highlight-bullet {
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: var(--gold);
  flex-shrink: 0;
}

.highlight-text {
  flex: 1;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.meta-list {
  display: flex;
  flex-direction: column;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(226, 199, 159, 0.08);
}

.meta-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.meta-label {
  flex-shrink: 0;
  color: var(--ink-faint);
  font-size: 21rpx;
  line-height: 1.5;
}

.meta-value {
  text-align: right;
  color: var(--ink);
  font-size: 21rpx;
  line-height: 1.54;
}

.sticky-action {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  z-index: 24;
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(226, 199, 159, 0.08);
  background:
    linear-gradient(180deg, rgba(20, 15, 14, 0.98), rgba(11, 9, 8, 0.98)),
    rgba(11, 9, 8, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(0, 0, 0, 0.14);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.sticky-button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.sticky-button-secondary {
  border: 1rpx solid rgba(214, 177, 124, 0.18);
  background: rgba(244, 235, 225, 0.04);
  color: var(--ink);
}

.sticky-button-secondary-hover {
  background: rgba(244, 235, 225, 0.08);
}

.sticky-button-primary {
  box-shadow: none;
}

.sticky-button-primary-hover {
  opacity: 0.9;
}

.sticky-button[disabled] {
  opacity: 0.4;
  box-shadow: none;
}
