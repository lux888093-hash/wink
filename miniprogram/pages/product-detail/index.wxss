.product-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 236rpx;
}

.hero-gallery {
  min-height: 520rpx;
  border-radius: 36rpx;
}

.hero-gallery-main,
.hero-gallery-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-gallery-mask {
  background:
    linear-gradient(180deg, rgba(8, 6, 5, 0.08) 0%, rgba(8, 6, 5, 0.88) 100%),
    radial-gradient(circle at 82% 10%, rgba(245, 219, 176, 0.2), rgba(245, 219, 176, 0));
}

.hero-gallery-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 520rpx;
  padding: 32rpx 28rpx 28rpx;
}

.hero-gallery-strip {
  display: flex;
  gap: 10rpx;
}

.hero-gallery-thumb {
  flex: 1;
  height: 104rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(214, 177, 124, 0.08);
}

.product-paper {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
}

.product-title {
  margin: 10rpx 0 8rpx;
}

.hero-gallery-subtitle {
  max-width: 440rpx;
}

.product-price {
  margin-top: 4rpx;
}

.sku-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.sku-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 74rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(75, 55, 35, 0.12);
  background: rgba(75, 55, 35, 0.04);
  color: var(--paper-ink);
}

.sku-chip.is-active {
  border-color: rgba(125, 83, 39, 0.24);
  background: rgba(214, 177, 124, 0.12);
}

.sku-name {
  font-size: 22rpx;
}

.sku-meta {
  font-size: 16rpx;
  color: rgba(43, 33, 27, 0.64);
}

.detail-panel,
.highlight-panel {
  padding: 24rpx;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-grid-item {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: calc(50% - 6rpx);
  min-height: 116rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(244, 235, 225, 0.04);
  border: 1rpx solid rgba(214, 177, 124, 0.08);
}

.detail-label {
  color: var(--ink-faint);
  font-size: 16rpx;
}

.detail-value {
  color: var(--ink);
  font-size: 19rpx;
  line-height: 1.46;
}

.highlight-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.highlight-card {
  width: calc(50% - 6rpx);
  min-height: 122rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(244, 235, 225, 0.04);
  border: 1rpx solid rgba(214, 177, 124, 0.08);
}

.highlight-index {
  display: block;
  margin-bottom: 12rpx;
  color: var(--gold);
  font-size: 18rpx;
  letter-spacing: 0.18em;
}

.sticky-action {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 20;
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
}

.sticky-button {
  flex: 1;
}
