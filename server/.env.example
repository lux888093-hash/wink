APP_ENV=development
PORT=3100
MINIPROGRAM_BASE_URL=http://127.0.0.1:3100
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3100,http://localhost:3100
JSON_BODY_LIMIT=256kb

DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSL=false

ADMIN_SESSION_DAYS=3
MAX_ADMIN_SESSIONS_PER_USER=5
ADMIN_SESSION_PEPPER=replace-this-pepper-in-production
ADMIN_BOOTSTRAP_PASSWORD=Curator!2026

LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=8
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=180
ENABLE_DEV_RESET=true

MINIAPP_SESSION_SECRET=replace-this-miniapp-secret
